<UserControl x:Class="PresentationWpf.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PresentationWpf.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP STATISTICS MENU ================= -->

        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Background="{StaticResource AdminTopBackground}"
                    Height="45">

            <RadioButton Content="Продажи по регионам"
                         Style="{StaticResource AdminTopButtonStyle}"
                         IsChecked="{Binding IsTotalByRegionSelected}"
                         Command="{Binding TotalByRegionCommand}"/>

            <RadioButton Content="Продажи по менеджерам"
                         Style="{StaticResource AdminTopButtonStyle}"
                         IsChecked="{Binding IsTotalByManagerSelected}"
                         Command="{Binding TotalByManagerCommand}"/>

            <RadioButton Content="Динамика продажи"
              Style="{StaticResource AdminTopButtonStyle}"
              IsChecked="{Binding IsSalesDinamicsSelected}"
              Command="{Binding SalesDinamicsCommand}"/>

            <RadioButton Content="Динамика по клиентам"
              Style="{StaticResource AdminTopButtonStyle}"
              IsChecked="{Binding IsCustomerSalesReimbSelected}"
              Command="{Binding CustomerSalesReimbCommand}"/>

        </StackPanel>

        <!-- ================= STATISTICS CONTENT ================= -->

        <ContentControl Grid.Row="1"
                        Content="{Binding CurrentStatisticsView}"/>

    </Grid>

</UserControl>
