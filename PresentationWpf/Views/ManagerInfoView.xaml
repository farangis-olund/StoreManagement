<UserControl x:Class="PresentationWpf.Views.ManagerInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="900">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="МЕНЕДЖЕРЫ" FontSize="18" Margin="0,0,0,10"/>

        <!-- ===== HEADER BUTTONS ===== -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
            <Button Content="Добавить" Style="{StaticResource GrayButton}"
                    Command="{Binding AddCommand}"
                    Width="100"
                    Margin="0,0,5,0"/>
            <Button Content="Изменить" Style="{StaticResource GrayButton}"
                    Command="{Binding UpdateCommand}"
                    Width="100"
                    Margin="0,0,5,0"/>
            <Button Content="Удалить" Style="{StaticResource GrayButton}"
                    Command="{Binding DeleteCommand}"
                    Width="100"
                    Margin="0,0,5,0"/>
            <Button Content="Сохранить" Style="{StaticResource GrayButton}"
                    Command="{Binding SaveCommand}"
                    Width="100"/>
        </StackPanel>

        <!-- ===== INPUT FIELDS (like UserView) ===== -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                <TextBlock Text="Код менеджера" FontSize="12" Margin="0,0,0,2"/>
                <TextBox FontSize="14"
                     Text="{Binding SelectedManager.Id}"
                     IsReadOnly="True"
                     Height="30"
                     Background="#F0F0F0"        
                     BorderBrush="#CCC"
                     Foreground="Black"
             Cursor="Arrow"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,5,0">
                <TextBlock Text="ФИО" FontSize="12" Margin="0,0,0,2"/>
                <TextBox FontSize="14" Text="{Binding SelectedManager.FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="0,0,5,0">
                <TextBlock Text="Адрес" FontSize="12" Margin="0,0,0,2"/>
                <TextBox FontSize="14" Text="{Binding SelectedManager.Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
            </StackPanel>

            <StackPanel Grid.Column="3">
                <TextBlock Text="Контакты" FontSize="12" Margin="0,0,0,2"/>
                <TextBox FontSize="14" Text="{Binding SelectedManager.Contacts, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
            </StackPanel>

            <StackPanel Grid.Column="4">
                <TextBlock Text="Активен" FontSize="12" Margin="0,0,0,2" HorizontalAlignment="Center"/>
                <CheckBox IsChecked="{Binding SelectedManager.Active, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ===== DATAGRID ===== -->
        <DataGrid Grid.Row="3"   Style="{StaticResource SummaryGrid}"
                  ItemsSource="{Binding Managers}"
                  SelectedItem="{Binding SelectedManager, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  Margin="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код" Binding="{Binding Id}" Width="*"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="2*"/>
                <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="2*"/>
                <DataGridTextColumn Header="Контакты" Binding="{Binding Contacts}" Width="2*"/>
                <DataGridCheckBoxColumn Header="Активен" Binding="{Binding Active}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
