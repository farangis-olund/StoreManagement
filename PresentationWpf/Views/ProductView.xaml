<UserControl x:Class="PresentationWpf.Views.ProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:PresentationWpf.ViewModels"
             
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000" Background="#D4D4D4">

    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Search -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
        </Grid.RowDefinitions>


        <!-- === HEADER WITH CLOSE BUTTON === -->
        <DockPanel Grid.Row="0"  Height="35">
            
            <Button Content="X" 
                    HorizontalAlignment="Right"
                    Style="{StaticResource CloseButton}"
                    DockPanel.Dock="Right"
                    Margin="0,0,10,0"
                     Command="{Binding CloseCommand}"/>
        </DockPanel>
        
        <!-- === TOP MENU === -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Height="45" >
            <Button Content="Сохранить" Style="{StaticResource GrayButton}" Command="{Binding SaveCommand}" Margin="5"/>
            
            <Button Content="Удалить" Style="{StaticResource GrayButton}" 
                    Command="{Binding DeleteCommand}" Margin="5" 
                    CommandParameter="{Binding SelectedItems, ElementName=ProductsGrid}"/>
           
        </StackPanel>

        <!-- === SEARCH === -->
        <Grid Grid.Row="2" Margin="5,5,5,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <CheckBox Content="Поиск всех кл.слов" 
                      VerticalAlignment="Center" 
                      FontSize="14" 
                      Foreground="#e67e22" 
                      Margin="10,0,0,0" 
                      IsChecked="{Binding SearchAllWords}" />
            <TextBox Width="400" Height="45" Grid.Row="1"
                     Margin="5,7"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Center"
                     Style="{StaticResource RoundedTextBoxStyle}"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <!-- === GRID === -->
        <DataGrid Grid.Row="3"
                  x:Name="ProductsGrid"
                  ItemsSource="{Binding ProductsView}"
                  SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="True"
                  CanUserDeleteRows="True"
                  Margin="5"
                  IsReadOnly="False"
                  RowHeaderWidth="20"
                  Style="{StaticResource SummaryGrid}"
                  PreviewKeyDown="ProductsGrid_OnPreviewKeyDown">

            <DataGrid.Columns>
                <!-- Текстовые -->
                <DataGridTextColumn Header="Артикул" Binding="{Binding ArticleNumber}"
                                    ElementStyle="{StaticResource TextCellStyle}" />
                <DataGridTextColumn Header="Название" Binding="{Binding ProductName}"
                                    ElementStyle="{StaticResource TextCellStyle}" />
                <DataGridTextColumn Header="Модель" Binding="{Binding Model}"
                                    ElementStyle="{StaticResource TextCellStyle}" />
                <DataGridTextColumn Header="Марка" Binding="{Binding Marka}"
                                    ElementStyle="{StaticResource TextCellStyle}" />
                <DataGridTextColumn Header="Альтернатива" Binding="{Binding Alternative}"
                                    ElementStyle="{StaticResource TextCellStyle}" />
                <DataGridTextColumn Header="Группа" Binding="{Binding GroupName}"
                                    ElementStyle="{StaticResource TextCellStyle}" />
                <DataGridTextColumn Header="Бренд" Binding="{Binding BrandName}"
                                    ElementStyle="{StaticResource TextCellStyle}" />
                <DataGridTextColumn Header="Склад" Binding="{Binding WarehousePlace}"
                                    ElementStyle="{StaticResource TextCellStyle}" />

                <!-- Числовые -->
                <DataGridTextColumn Header="Количество" Binding="{Binding Quentity}"
                                    ElementStyle="{StaticResource NumberCellStyle}" />
                <DataGridTextColumn Header="Мин. остаток" Binding="{Binding MinRemainingQuantity}"
                                    ElementStyle="{StaticResource NumberCellStyle}" />
                <DataGridTextColumn Header="Розн. €" Binding="{Binding RetailPriceEuro}"
                                    ElementStyle="{StaticResource NumberCellStyle}" />
                <DataGridTextColumn Header="Опт. €" Binding="{Binding WholesalePriceEuro}"
                                    ElementStyle="{StaticResource NumberCellStyle}" />
                <DataGridTextColumn Header="Серв. €" Binding="{Binding ServicePriceEuro}"
                                    ElementStyle="{StaticResource NumberCellStyle}" />
                <DataGridTextColumn Header="Опт1. €" Binding="{Binding WholesalePrice1Euro}"
                                    ElementStyle="{StaticResource NumberCellStyle}" />
                <DataGridTextColumn Header="Нетто" Binding="{Binding NetPrice}"
                                    ElementStyle="{StaticResource NumberCellStyle}" />
                <DataGridTextColumn Header="Мелк. опт" Binding="{Binding SmallWholesalePrice}"
                                    ElementStyle="{StaticResource NumberCellStyle}" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
