<UserControl x:Class="PresentationWpf.Views.RoleManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:local="clr-namespace:PresentationWpf.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1200">

    <UserControl.Resources>
      

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="#EFEFEF"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4"
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#333"/>
        </Style>

        <!-- DELETE BUTTON (RED) -->
        <Style x:Key="DeleteIconButton" BasedOn="{StaticResource IconButton}" TargetType="Button">
            <Setter Property="Background" Value="#C62828"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#8E0000"/>
        </Style>

    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>       <!-- Shared Roles+Permissions group -->
            <ColumnDefinition x:Name="PermissionManagerColumn">
                <ColumnDefinition.Style>
                    <Style TargetType="ColumnDefinition">
                        <Setter Property="Width" Value="0"/>
                        <!-- Hidden by default -->

                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPermissionManagerVisible}" Value="True">
                                <Setter Property="Width" Value="520"/>
                                <!-- Visible when toggled -->
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ColumnDefinition.Style>
            </ColumnDefinition>
            
        </Grid.ColumnDefinitions>

        <!-- 🔵 SHARED BORDER FOR ROLES + PERMISSIONS -->
        <Border Grid.Column="0"
            Margin="0"
            Padding="20"
            Background="#FAFAFA"
            BorderBrush="#CCC"
            BorderThickness="1"
            CornerRadius="10">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>
               
                
                <!-- ==================LEFT PANEL: ROLES ================================= -->
              
                <Border Grid.Column="0"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Left"
                    Width="295"
                    Padding="15"
                    Background="#F7F7F7"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    CornerRadius="8">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>      <!-- Title -->
                            <RowDefinition Height="*"/>         <!-- Scroll viewer -->
                            <RowDefinition Height="Auto"/>      <!-- Buttons at bottom -->
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Роли"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                        <ScrollViewer Grid.Row="1" Height="400"
                                  VerticalScrollBarVisibility="Auto" VerticalAlignment="Top">

                            <ListBox ItemsSource="{Binding Roles}"
                                 SelectedItem="{Binding SelectedRole}"
                                 BorderThickness="0"
                                 Background="Transparent">

                                <ListBox.ItemTemplate>
                                    <DataTemplate>

                                        <Border BorderBrush="#DDD"
                                            BorderThickness="1"
                                            Padding="5"
                                            Margin="0,0,0,5"
                                            CornerRadius="4"
                                            MinHeight="40"
                                            Background="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem},
                                                Path=IsSelected,
                                                Converter={StaticResource BoolToColorConverter}}">

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="170"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- DISPLAY MODE -->
                                                <TextBlock Text="{Binding RoleName}"
                                                       VerticalAlignment="Center"
                                                       Width="160"
                                                       FontSize="15"
                                                       Visibility="{Binding IsEditing,
                                                            Converter={StaticResource BoolToVisibilityConverter2},
                                                            ConverterParameter=Invert}" />

                                                <!-- EDIT MODE -->
                                                <TextBox Text="{Binding RoleName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="160"
                                                     Padding="6,3"
                                                     FontSize="15"
                                                     VerticalAlignment="Center"
                                                     Visibility="{Binding IsEditing,
                                                            Converter={StaticResource BoolToVisibilityConverter2}}" />

                                                <!-- EDIT BUTTON -->
                                                <Button Style="{StaticResource IconButton}"
                                                    Grid.Column="1"
                                                    Width="30"
                                                    Height="28"
                                                    Command="{Binding DataContext.EditRoleCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                    <fa:ImageAwesome Icon="Pencil"
                                                                 Width="12"
                                                                 Height="12"
                                                                 Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                </Button>

                                                <!-- DELETE BUTTON -->
                                                <Button Style="{StaticResource DeleteIconButton}"
                                                    Grid.Column="2"
                                                    Width="30"
                                                    Height="28"
                                                    Margin="5,0,0,0"
                                                    Command="{Binding DataContext.DeleteRoleCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                    <fa:ImageAwesome Icon="Trash"
                                                                 Width="12"
                                                                 Height="12"
                                                                 Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                </Button>

                                            </Grid>
                                        </Border>

                                    </DataTemplate>
                                </ListBox.ItemTemplate>

                            </ListBox>

                        </ScrollViewer>

                        <!-- Buttons -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,0">

                            <Button Style="{StaticResource GrayButton}"
                                Width="127"
                                Height="32"
                                Command="{Binding AddRoleCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Plus"
                                                 Width="14"
                                                 Height="14"
                                                 Margin="0,0,6,0"
                                                 Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="Добавить роль"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource GrayButton}"
                                Margin="10,0,0,0"
                                Width="120"
                                Height="32"
                                Command="{Binding SaveRoleCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Save"
                                                 Width="16"
                                                 Height="16"
                                                 Margin="0,0,6,0"
                                                 Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="Сохранить"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>

                    </Grid>

                </Border>

                <!-- =========================== RIGHT PANEL: PERMISSIONS  ============================= -->
               
                <Border Grid.Column="1"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Left"
                    Padding="15"
                    Width="295"
                    Background="#F7F7F7"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    CornerRadius="8">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>                    <!-- Title -->
                            <RowDefinition Height="*"/>                    <!-- Scroll viewer -->
                            <RowDefinition Height="Auto"/>                    <!-- Buttons at bottom -->
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock 
                                   Text="Права доступа"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   DockPanel.Dock="Left"/>
                            <!-- Settings button -->
                            <Button Style="{StaticResource GrayButton}"
                                     Command="{Binding TogglePermissionManagerCommand}"
                                     Width="40"
                                     Height="35"
                                     Margin="50,0,0,0" DockPanel.Dock="Right">
                                    <StackPanel Orientation="Horizontal">
                                        <fa:ImageAwesome Icon="Gear"
                                            Width="14"
                                            Height="14"
                                            Margin="0,0,0,0"
                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text=""/>
                                </StackPanel>
                            </Button>

                        </DockPanel>

                        <StackPanel Grid.Row="1">

                            <!-- SELECT ALL / UNSELECT ALL -->
                            <CheckBox Content="Выбрать все"
                                  FontWeight="Bold"
                                  Margin="0,0,0,10"
                                  Visibility="{Binding IsPermissionsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                  IsChecked="{Binding AreAllSelected, Mode=TwoWay}" />

                            <!-- PERMISSIONS LIST -->
                            <ScrollViewer Height="400"
                                  VerticalAlignment="Top"
                                  VerticalScrollBarVisibility="Auto">

                                <ItemsControl ItemsSource="{Binding Permissions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Description}"
                                              IsChecked="{Binding IsAssigned, Mode=TwoWay}"
                                              FontSize="14"
                                              Margin="0,5,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </ScrollViewer>

                        </StackPanel>


                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">

                            <!-- Save button -->
                            <Button Style="{StaticResource GrayButton}"
                                Command="{Binding SavePermissionsCommand}"
                                Width="120"
                                Height="32">
                                <StackPanel Orientation="Horizontal">
                                    <fa:ImageAwesome Icon="Save" Width="16" Height="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="Сохранить"/>
                                </StackPanel>
                            </Button>

                           
                        </StackPanel>


                    </Grid>

                </Border>

            </Grid>

        </Border>

        <!-- =======================COLUMN 2: PERMISSION MANAGER  ================================= -->

        <Border Grid.Column="1"
        Padding="15"
        Width="500"
        VerticalAlignment="Stretch"
        HorizontalAlignment="Left"
        Background="#F7F7F7"
        CornerRadius="8"
        BorderBrush="#DDD"
        BorderThickness="1"
        Margin="20,0,0,0">

            <ContentControl Content="{Binding PermissionManagementView}"/>
        </Border>

    </Grid>


</UserControl>
