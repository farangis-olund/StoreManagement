<UserControl x:Class="PresentationWpf.Views.SalesDynamicsStatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PresentationWpf.Views"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FILTERS -->

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

            <TextBlock Text="Период с:" VerticalAlignment="Center"/>

            <DatePicker SelectedDate="{Binding FromDate}"
                Width="130"
                Height="30"
                Margin="5,0"/>

            <TextBlock Text="по:" VerticalAlignment="Center"/>

            <DatePicker SelectedDate="{Binding ToDate}"
                Width="130"
                Height="30"
                Margin="5,0"/>

            <TextBlock Text="Фирма:" VerticalAlignment="Center"/>

            <ComboBox Width="150" Height="30"  IsEditable="True"
                IsTextSearchEnabled="True"
                ItemsSource="{Binding Firmas}"
                SelectedItem="{Binding SelectedFirma}"
                Margin="5,0"/>
           

        </StackPanel>

        <!-- CHART -->

        <lvc:CartesianChart Grid.Row="1"
                    Series="{Binding SeriesCollection}"
                    LegendLocation="Right">

            <lvc:CartesianChart.AxisX>
                <lvc:Axis Labels="{Binding Labels}"
                  Title="Месяцы"
                  LabelsRotation="35">
                    <lvc:Axis.Separator>
                        <lvc:Separator Step="1"/>
                    </lvc:Axis.Separator>
                </lvc:Axis>
            </lvc:CartesianChart.AxisX>

            <lvc:CartesianChart.AxisY>
                <lvc:Axis Title="Сумма продаж"
                  LabelFormatter="{Binding Formatter}"
                  FontSize="13"
                  Foreground="#2C3E50">

                    <lvc:Axis.Separator>
                        <lvc:Separator Stroke="#E0E0E0"
                               StrokeThickness="1"/>
                    </lvc:Axis.Separator>

                </lvc:Axis>
            </lvc:CartesianChart.AxisY>

        </lvc:CartesianChart>
    </Grid>
</UserControl>
