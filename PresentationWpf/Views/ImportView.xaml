<UserControl x:Class="PresentationWpf.Views.ImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PresentationWpf.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header row -->
            <RowDefinition Height="Auto"/>
            <!-- Date + Action buttons -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- Close button in header (top-right) -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <!-- left side (text) -->
                <ColumnDefinition Width="Auto" />
                <!-- right side (button) -->
            </Grid.ColumnDefinitions>

            <!-- 🟢 Title on the left -->
            <TextBlock Text="ИМПОРТ ТОВАРОВ"
               FontSize="18"
               FontWeight="Bold"
               VerticalAlignment="Center"
               HorizontalAlignment="Left"
               Foreground="#333"
               Margin="10,0,0,0"/>

            <!-- 🔴 Close button on the right -->
            <Button Content="X"
            Style="{StaticResource CloseButton}"
            Command="{Binding CloseCommand}"
            Grid.Column="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,5,5,0"/>
        </Grid>


        <!-- Date + Action buttons row -->
        <Grid Grid.Row="1" Margin="0,20,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <!-- Date section -->
                <ColumnDefinition Width="*"/>
                <!-- Spacer -->
                <ColumnDefinition Width="Auto"/>
                <!-- Buttons -->
            </Grid.ColumnDefinitions>

            <!-- Date selector (left) -->
            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <TextBlock Text="Дата:" VerticalAlignment="Center" FontSize="14" Margin="0,0,10,0"/>
                <!-- Date picker (left side) -->
                <ComboBox Width="160" Height="30" VerticalAlignment="Center" FontSize="16"
                      ItemsSource="{Binding AvailableDates}"
                      SelectedItem="{Binding SelectedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                           <TextBlock Text="{Binding StringFormat={}{0:dd.MM.yyyy}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

            </StackPanel>

            <!-- Action buttons (right) -->
            <StackPanel Orientation="Horizontal" Grid.Column="2">
                 <Button Content="Отчёт" Width="100" Height="30" Margin="0,0,10,0" Style="{StaticResource GrayButton}"
                        Command="{Binding OpenReportCommand}" IsEnabled="{Binding CanPrint}"/>
                <Button Content="Экспорт" Width="100" Height="30" Margin="0,0,10,0" Style="{StaticResource GrayButton}"
                        Command="{Binding ExportCommand}" IsEnabled="{Binding CanExport}"/>
                <Button Content="Обновить" Width="100" Height="30" Margin="0,0,0,0" Style="{StaticResource GrayButton}"
                        Command="{Binding UpdateCommand}" IsEnabled="{Binding CanUpdate}"/>
            </StackPanel>
        </Grid>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2"
          ItemsSource="{Binding Rows}"   
          Style="{StaticResource SummaryGrid}"
          AutoGenerateColumns="False"
          IsReadOnly="True"
          Margin="0">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Артикул"       Binding="{Binding ArticleNumber}" />
                <DataGridTextColumn Header="Наименование"  Binding="{Binding ProductName}"   />
                <DataGridTextColumn Header="Группа"        Binding="{Binding GroupName}"     />
                <DataGridTextColumn Header="Бренд"         Binding="{Binding BrandName}"     />
                <DataGridTextColumn Header="Модель"        Binding="{Binding Model}"         />
                <DataGridTextColumn Header="Количество"    Binding="{Binding Quantity}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>


    </Grid>
</UserControl>
