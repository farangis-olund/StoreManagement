<UserControl x:Class="PresentationWpf.Views.CustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PresentationWpf.Views"
              xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:views="clr-namespace:PresentationWpf.Views"
             xmlns:viewmodels="clr-namespace:PresentationWpf.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:CustomerViewModel}"
             mc:Ignorable="d" 
           
             d:DesignHeight="450" d:DesignWidth="900">
    <UserControl.Resources>
        <Style x:Key="TransparentHoverButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#302D3E"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Normal"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="4"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">

                            <ContentPresenter x:Name="contentPresenter"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- 🔵 HOVER EFFECT -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EEE"/>
                                <Setter Property="Foreground" Value="#000"/>
                                <!-- Text + Icon -->
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black"/>
           
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,5,0,2"/>
        </Style>
    </UserControl.Resources>



    <DockPanel>
        <!-- Top Toolbar -->
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Background="#E0E5E6" Height="40" VerticalAlignment="Top">
            <Label Content="Перейти" VerticalAlignment="Center" Margin="5,0" Foreground="#302D3E" />
            <ComboBox Width="180" Height="27"
              Margin="0,0,20,0"
              VerticalAlignment="Center"
              FontSize="14"
              IsEditable="True"
              IsTextSearchEnabled="True"
              ItemsSource="{Binding Customers}"
              SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
              DisplayMemberPath="{Binding CustomerDisplayMemberPath}"
              StaysOpenOnEdit="True"
              TextSearch.TextPath="{Binding CustomerDisplayMemberPath}" />

            <Button Command="{Binding CreateCustomerCommand}" 
            Style="{StaticResource TransparentHoverButton}" 
            Margin="0,0,15,0" 
            Width="160" 
            VerticalAlignment="Center">

                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Plus" 
                             
                             Width="12" 
                             Height="12" 
                             Margin="0,5,6,0"
                             VerticalAlignment="Center"  
                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                             <TextBlock Text="Новый клиент" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding SaveCustomerCommand}" 
                Style="{StaticResource TransparentHoverButton}" 
                Margin="0,0,15,0" 
                Width="120" 
                VerticalAlignment="Center">

                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Save" 
                                 Width="14" 
                                 Height="14" 
                                 Margin="0,5,6,0"
                                 VerticalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Сохранить" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto" >
            <Grid Margin="10" HorizontalAlignment="left"  Width="auto" MaxWidth="1000">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>

                <!-- Left Column -->
                <StackPanel Grid.Column="0" Margin="10,10,10,10" DataContext="{Binding SelectedCustomer}" >
                    <!-- ФИО -->
                    <TextBlock >
                          <Run Text="ФИО" Foreground="Black"/>
                          <Run Text="*" Foreground="Red"/>
                    </TextBlock>
                    <TextBox Height="32" Margin="0,0,0,5" VerticalContentAlignment="Center" Padding="5"
                Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>

                    <!-- Email -->
                    <TextBlock Text="Email" />
                    <TextBox Height="32" Margin="0,0,0,5" VerticalContentAlignment="Center" Padding="5"
                    Text="{Binding Email,UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>

                    <!-- Мобильный телефон -->
                    <TextBlock >
                        <Run Text="Мобильный телефон" Foreground="Black"/>
                        <Run Text="*" Foreground="Red"/>
                    </TextBlock>
                    
                    <TextBox Height="32" Margin="0,0,0,5" VerticalContentAlignment="Center" Padding="5"
                    Text="{Binding MobilePhone, UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>

                    <!-- Адрес -->
                    <TextBlock >
                        <Run Text="Адрес" Foreground="Black"/>
                        <Run Text="*" Foreground="Red"/>
                    </TextBlock>
                    <TextBox Height="32" Margin="0,0,0,5" VerticalContentAlignment="Center" Padding="5"
                    Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" FontSize="14" />

                    <!-- Город -->
                    <TextBlock >
                            <Run Text="Город" Foreground="Black"/>
                            <Run Text="*" Foreground="Red"/>
                    </TextBlock>
                    <ComboBox Height="32" Margin="0,0,0,5" Padding="5"
                          ItemsSource="{Binding DataContext.DistinctCities, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          SelectedItem="{Binding City, Mode=TwoWay}"
                          Text="{Binding City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          FontSize="14"/>

                    <!-- Область -->
                    <TextBlock >
                        <Run Text="Область" Foreground="Black"/>
                        <Run Text="*" Foreground="Red"/>
                    </TextBlock>
                    <ComboBox Height="32" Margin="0,0,0,5" Padding="5"
                      ItemsSource="{Binding DataContext.DistinctRegions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      SelectedItem="{Binding Region, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Text="{Binding Region, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      IsEditable="True"
                      FontSize="14"/>


                </StackPanel>

                <!-- Middle Column -->
                <StackPanel Grid.Column="1" Margin="10,10,10,10" DataContext="{Binding SelectedCustomer}">
                    <TextBlock >
                        <Run Text="Уровень" Foreground="Black"/>
                        <Run Text="*" Foreground="Red"/>
                    </TextBlock>
                    <ComboBox Height="32" Margin="0,0,0,5" FontSize="14" VerticalContentAlignment="Center" Padding="5"
                      ItemsSource="{Binding DataContext.PriceLevels, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      DisplayMemberPath="PriceType"
                      SelectedValuePath="Level"
                      SelectedValue="{Binding PriceLevelId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />


                    <TextBlock Text="Примечания" />
                    <TextBox Height="60" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,5" FontSize="14" VerticalContentAlignment="Center" Padding="5"
                    Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />
                    
                    <StackPanel Visibility="{Binding DataContext.CanViewDebt,
                     RelativeSource={RelativeSource AncestorType=UserControl},
                     Converter={StaticResource BoolToVisibilityConverter}}">                       
                        <TextBlock Text="Задолжность" />
                        <TextBox Height="32" Margin="0,0,0,5" Text="{Binding Debt, UpdateSourceTrigger=PropertyChanged}" FontSize="14" VerticalContentAlignment="Center" Padding="5" />
                    </StackPanel>
                    
                    <StackPanel Visibility="{Binding DataContext.CanViewRestriction,
                     RelativeSource={RelativeSource AncestorType=UserControl},
                     Converter={StaticResource BoolToVisibilityConverter}}">
                         <TextBlock Text="Ограничение" />
                        <TextBox Height="32" Margin="0,0,0,5" Text="{Binding Restriction, UpdateSourceTrigger=PropertyChanged}" FontSize="14" VerticalContentAlignment="Center" Padding="5"/>
                    </StackPanel>

                    <TextBlock Text="Лимит неоплаченных платежей" />
                    <TextBox Height="32" Margin="0,0,0,5" Text="{Binding UnpaidPaymentLimit, UpdateSourceTrigger=PropertyChanged}" FontSize="14" VerticalContentAlignment="Center" Padding="5"/>
                
                </StackPanel>

                <!-- Right Column -->
                <StackPanel Grid.Column="2" Margin="10,10,10,10"  DataContext="{Binding SelectedCustomer}" >
                    <TextBlock Text="КоэфОгрСумЗакупа" />
                    <TextBox IsReadOnly="True" Height="32" Margin="0,0,0,5" Text="{Binding DailyPurchaseCoefficient, UpdateSourceTrigger=PropertyChanged}" FontSize="14" VerticalContentAlignment="Center" Padding="5"/>
                    <TextBlock Text="КоэфЕжедПогашение" />
                    <TextBox IsReadOnly="True" Height="32" Margin="0,0,0,5" Text="{Binding DailyRepaymentCoefficient, UpdateSourceTrigger=PropertyChanged}" FontSize="14" VerticalContentAlignment="Center" Padding="5"/>
                    <TextBlock Text="КоэфПланирЗакупа" />
                    <TextBox IsReadOnly="True" Height="32" Margin="0,0,0,5" Text="{Binding DailyPlannedPurchaseCoefficient, UpdateSourceTrigger=PropertyChanged}" FontSize="14" VerticalContentAlignment="Center" Padding="5"/>

                    <TextBlock Text="Дата контракта" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <DatePicker Width="120"
                            SelectedDate="{Binding ContractDate, UpdateSourceTrigger=PropertyChanged}"
                            FontSize="14"
                            VerticalContentAlignment="Center"
                            Padding="5" />
                        <Button Content="Расчет коэф"
                            Width="100"
                            Margin="5,0,0,0"
                            Command="{Binding DataContext.CalculateCoefficientsForCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />

                    </StackPanel>

                    <TextBlock >
                        <Run Text="Территория" Foreground="Black"/>
                        <Run Text="*" Foreground="Red"/>
                    </TextBlock>
                    <ComboBox Height="32" Margin="0,0,0,5" Padding="5"
                       ItemsSource="{Binding DataContext.DistinctTerritories, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        SelectedItem="{Binding Territory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Text="{Binding Territory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"    
                      IsEditable="True"
                      FontSize="14"/>
                    
                    <CheckBox Content="ИсключитьЕжедПогашение"  IsChecked="{Binding ExcludeMonthlyRepayment, UpdateSourceTrigger=PropertyChanged}" FontSize="14"  Margin="0,0,0,5" />

                    <TextBlock >
                        <Run Text="Менеджер по продажам" Foreground="Black"/>
                        <Run Text="*" Foreground="Red"/>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal">
                        <ComboBox Width="180"
                          Height="32"
                          FontSize="14"
                          VerticalContentAlignment="Center"
                          Padding="5"
                          ItemsSource="{Binding DataContext.SalesManagers, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          DisplayMemberPath="FullName"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SalesManagerId, UpdateSourceTrigger=PropertyChanged}" />

                        <CheckBox Margin="30,0,0,0" FontSize="20" 
                          VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                          IsChecked="{Binding OfficialCustomer, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer> 
    </DockPanel>
</UserControl>

    
    
