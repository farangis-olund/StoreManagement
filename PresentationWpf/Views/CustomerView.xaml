<UserControl x:Class="PresentationWpf.Views.CustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PresentationWpf.Views"
             
             xmlns:views="clr-namespace:PresentationWpf.Views"
             xmlns:viewmodels="clr-namespace:PresentationWpf.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:CustomerViewModel}"
             mc:Ignorable="d" 
           
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="TransparentHoverButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#302D3E"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter x:Name="contentPresenter"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                               
                                <Setter TargetName="contentPresenter" Property="TextElement.FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E6762F"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,5,0,2"/>
        </Style>
    </UserControl.Resources>



    <DockPanel>
        <!-- Top Toolbar -->
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Background="#E0E5E6" Height="40" VerticalAlignment="Top">
            <Label Content="Перейти" VerticalAlignment="Center" Margin="5,0" Foreground="#302D3E" />
            <ComboBox Width="180" Height="27"
              Margin="0,0,20,0"
              VerticalAlignment="Center"
              FontSize="14"
              IsEditable="True"
              IsTextSearchEnabled="True"
              ItemsSource="{Binding Customers}"
              SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
              DisplayMemberPath="DisplayText"
              StaysOpenOnEdit="True"
              TextSearch.TextPath="DisplayText" />

            <Button Content="Создать" Command="{Binding CreateCustomerCommand}" Style="{StaticResource TransparentHoverButton}" Margin="0,0,15,0" Width="100" VerticalAlignment="Center"/>
            <Button Content="Сохранить" Command="{Binding SaveCustomerCommand}" Style="{StaticResource TransparentHoverButton}" Margin="0,0,15,0" Width="100" VerticalAlignment="Center"/>
            <Button Content="Удалить" Command="{Binding DeleteCustomerCommand}" Style="{StaticResource TransparentHoverButton}" Margin="0,0,15,0" Width="100" VerticalAlignment="Center"/>

        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto" >
            <Grid Margin="10" HorizontalAlignment="left"  Width="auto" MaxWidth="1000">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>

                <!-- Left Column -->
                <StackPanel Grid.Column="0" Margin="10,10,10,10" DataContext="{Binding SelectedCustomer}" >
                    <!-- ФИО -->
                    <TextBlock Text="ФИО" />
                    <TextBox Height="32" Margin="0,0,0,5" VerticalContentAlignment="Center" Padding="5"
                Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>

                    <!-- Email -->
                    <TextBlock Text="Email" />
                    <TextBox Height="32" Margin="0,0,0,5" VerticalContentAlignment="Center" Padding="5"
                    Text="{Binding Email,UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>

                    <!-- Мобильный телефон -->
                    <TextBlock Text="Мобильный телефон" />
                    <TextBox Height="32" Margin="0,0,0,5" VerticalContentAlignment="Center" Padding="5"
                    Text="{Binding MobilePhone, UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>

                    <!-- Адрес -->
                    <TextBlock Text="Адрес" />
                    <TextBox Height="32" Margin="0,0,0,5" VerticalContentAlignment="Center" Padding="5"
                    Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" FontSize="14" />

                    <!-- Город -->
                    <TextBlock Text="Город" />
                    <TextBox Height="32" Margin="0,0,0,5" VerticalContentAlignment="Center" Padding="5"
                    Text="{Binding City, UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>

                    <!-- Область -->
                    <TextBlock Text="Область" />
                    <TextBox Height="32" Margin="0,0,0,5" VerticalContentAlignment="Center" Padding="5"
                    Text="{Binding Region, UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>

                    <!-- Индекс -->
                    <TextBlock Text="Индекс" />
                    <TextBox Height="32" Margin="0,0,0,5" VerticalContentAlignment="Center" Padding="5"
                    Text="{Binding PostalCode, UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>

                </StackPanel>

                <!-- Middle Column -->
                <StackPanel Grid.Column="1" Margin="10,10,10,10" DataContext="{Binding SelectedCustomer}">
                    <TextBlock Text="Уровень" />
                    <ComboBox Height="32" Margin="0,0,0,5" FontSize="14" VerticalContentAlignment="Center" Padding="5"
                      ItemsSource="{Binding DataContext.PriceLevels, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      DisplayMemberPath="Level"
                      SelectedValuePath="Level"
                      SelectedValue="{Binding PriceLevelId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />


                    <TextBlock Text="Примечания" />
                    <TextBox Height="60" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,5" FontSize="14" VerticalContentAlignment="Center" Padding="5"
                    Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Задолжность" />
                    <TextBox Height="32" Margin="0,0,0,5" Text="{Binding Debt, UpdateSourceTrigger=PropertyChanged}" FontSize="14" VerticalContentAlignment="Center" Padding="5" />
                    <TextBlock Text="Ограничение" />
                    <TextBox Height="32" Margin="0,0,0,5" Text="{Binding Restriction, UpdateSourceTrigger=PropertyChanged}" FontSize="14" VerticalContentAlignment="Center" Padding="5"/>
                    </StackPanel>

                <!-- Right Column -->
                <StackPanel Grid.Column="2" Margin="10,10,10,10"  DataContext="{Binding SelectedCustomer}" >
                    <TextBlock Text="КоэфОгрСумЗакупа" />
                    <TextBox Height="32" Margin="0,0,0,5" Text="{Binding TotalPurchaseAmount, UpdateSourceTrigger=PropertyChanged}" FontSize="14" VerticalContentAlignment="Center" Padding="5"/>
                    <TextBlock Text="КоэфЕжедПогашение" />
                    <TextBox Height="32" Margin="0,0,0,5" Text="{Binding MonthlyRepaymentRate, UpdateSourceTrigger=PropertyChanged}" FontSize="14" VerticalContentAlignment="Center" Padding="5"/>
                    <TextBlock Text="КоэфПланирЗакупа" />
                    <TextBox Height="32" Margin="0,0,0,5" Text="{Binding PlannedPurchaseAmount, UpdateSourceTrigger=PropertyChanged}" FontSize="14" VerticalContentAlignment="Center" Padding="5"/>

                    <TextBlock Text="Дата контракта" />
                    <DatePicker Margin="0,0,0,5" SelectedDate="{Binding ContractDate, UpdateSourceTrigger=PropertyChanged}" FontSize="14" VerticalContentAlignment="Center" Padding="5"/>
                    <TextBlock Text="Территория" />
                    <TextBox Height="32" Margin="0,0,0,5" Text="{Binding Territory, UpdateSourceTrigger=PropertyChanged}" FontSize="14" VerticalContentAlignment="Center" Padding="5"/>
                    <CheckBox Content="ИсключитьЕжедПогашение"  IsChecked="{Binding ExcludeMonthlyRepayment, UpdateSourceTrigger=PropertyChanged}" FontSize="14"  Margin="0,0,0,5" />

                    <TextBlock Text="Менеджер по продажам" />
                    <ComboBox Height="32" Margin="0,0,0,5" FontSize="14" VerticalContentAlignment="Center" Padding="5"
                        ItemsSource="{Binding DataContext.SalesManagers, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        DisplayMemberPath="FullName"
                        SelectedValuePath="Id"
                        SelectedValue="{Binding SalesManagerId, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>
        </ScrollViewer> 
    </DockPanel>
</UserControl>

    
    
