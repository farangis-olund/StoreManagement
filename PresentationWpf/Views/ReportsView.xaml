<UserControl x:Class="PresentationWpf.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PresentationWpf.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP REPORT MENU ================= -->
       
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Background="{StaticResource AdminTopBackground}"
            Height="45">

               

                <RadioButton Content="Итоги по клиентам"
                         Style="{StaticResource AdminTopButtonStyle}"
                         IsChecked="{Binding IsCustomerSalesSummarySelected}"
                         Command="{Binding OpenCustomerSalesSummaryCommand}"/>

            <RadioButton Content="Итоги по группам"
                        Style="{StaticResource AdminTopButtonStyle}"
                        IsChecked="{Binding IsTotalByGroupSelected}"
                        Command="{Binding TotalByGroupCommand}"/>

                <RadioButton Content="Неактивные товары склада"
                        Style="{StaticResource AdminTopButtonStyle}"
                        IsChecked="{Binding IsInactiveWarehouseProductsSelected}"
                        Command="{Binding InactiveWarehouseProductsCommand}"/>

                <RadioButton Content="Итоги по доставщикам и складчикам"
                       Style="{StaticResource AdminTopButtonStyle}"
                       IsChecked="{Binding IsCourierStorekeeperReportSelected}"
                       Command="{Binding CourierStorekeeperReportCommand}"
                        />

            <RadioButton Content="Отчет по месту на складе"
                Style="{StaticResource AdminTopButtonStyle}"
                IsChecked="{Binding IsWarehousePlaceReportSelected}"
                Command="{Binding WarehousePlaceReportCommand}"
         />
            <RadioButton Content="Итоговый отчёт"
         Style="{StaticResource AdminTopButtonStyle}"
         IsChecked="{Binding IsSalesSummarySelected}"
         Command="{Binding OpenSalesSummaryCommand}"/>

        </StackPanel>
        

        <!-- ================= REPORT CONTENT ================= -->
        <ContentControl Grid.Row="1"
                        Content="{Binding CurrentReportView}"/>
    </Grid>
</UserControl>
