<UserControl x:Class="PresentationWpf.Views.ReturnsDayReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PresentationWpf.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <StackPanel Orientation="Horizontal"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Left">

            <ComboBox Width="160"
          Height="35"
          ItemsSource="{Binding ReturnDates}"
          SelectedItem="{Binding SelectedReturnDate}"
          IsEditable="True"
          IsTextSearchEnabled="True">

                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding StringFormat={}{0:dd.MM.yyyy}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>

            </ComboBox>

            <Button Content="Показать отчёт"
                    Width="140"
                    Height="35"
                    Margin="10,0,0,0"
                    Style="{StaticResource GrayButton}"
                    Command="{Binding ShowReportCommand}" />

        </StackPanel>
    </Grid>
</UserControl>
