<UserControl x:Class="PresentationWpf.Views.ExpenseCrudView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PresentationWpf.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>

        <!-- All TextBlocks -->
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- All TextBoxes -->
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- All ComboBoxes -->
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- All DatePickers -->
        <Style TargetType="DatePicker">
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="FilterCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F7F7FA"/>
            <Setter Property="BorderBrush" Value="#D9D9E3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <!--<Setter Property="CornerRadius" Value="8"/>-->
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>

        <Style x:Key="GridCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D9D9E3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <!--<Setter Property="CornerRadius" Value="8"/>-->
            <Setter Property="Padding" Value="0"/>
            
        </Style>

        <Style x:Key="ExpenseGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#222"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E6E6EE"/>
            <Setter Property="VerticalGridLinesBrush" Value="#F2F2F7"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="34"/>
            <Setter Property="ColumnHeaderHeight" Value="36"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFD"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F4F8"/>
            <Setter Property="Foreground" Value="#2B2B35"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#E1E3EA"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="TextBlock.TextAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#222"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F6FB"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DCE8F9"/>
                    <Setter Property="Foreground" Value="#111"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
    </UserControl.Resources>
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========================= -->
        <!-- TOP BUTTONS -->
        <!-- ========================= -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

            <Button Content="Добавить"
                    Command="{Binding AddCommand}"
                     Style="{StaticResource GrayButton}"
                     IsEnabled="{Binding CanAdd}"
                    Width="120" Margin="0,0,10,0"/>

            <Button Content="Сохранить"
            Command="{Binding SaveCommand}"
             Style="{StaticResource GrayButton}"
            Width="120" Margin="0,0,10,0"/>
            
            <Button Content="Удалить"
                    Command="{Binding DeleteCommand}"
                     Style="{StaticResource GrayButton}"
                    Width="120" Margin="0,0,10,0" Visibility="{Binding DataContext.CanViewRemove,
                     RelativeSource={RelativeSource AncestorType=UserControl},
                     Converter={StaticResource BoolToVisibilityConverter}}"/>

            <Button Content="Печать"
                    Command="{Binding PrintCommand}"
                     Style="{StaticResource GrayButton}"
                    Width="120"/>
        </StackPanel>

        <!-- ========================= -->
        <!-- INPUT FORM -->
        <!-- ========================= -->
        <Border Grid.Row="1" Padding="15" Background="#1E1E2E" CornerRadius="8">

            <StackPanel Orientation="Horizontal">

                <!-- DATE -->
                <StackPanel Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Дата" Foreground="White"/>
                        
                    </StackPanel>
                    <TextBox IsReadOnly="True" Text="{Binding Date, Mode=TwoWay, StringFormat={}{0:dd.MM.yyyy}}" Height="30" Width="120"/>
                </StackPanel>
               
                <StackPanel Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Сумма (TJS)" Foreground="White"/>
                        <TextBlock Text=" *" Foreground="Red" FontWeight="Bold"/>
                    </StackPanel>
                    <TextBox Text="{Binding AmountTjs, UpdateSourceTrigger=PropertyChanged}" Width="120" Height="30"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Сумма (EUR)" Foreground="White"/>
                    <TextBox Text="{Binding AmountEuro}" Width="120" Height="30" IsReadOnly="True" Background="Gainsboro"/>
                </StackPanel>

                <!-- REASON -->
                <StackPanel Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Причина" Foreground="White"/>
                        <TextBlock Text=" *" Foreground="Red" FontWeight="Bold"/>
                    </StackPanel>
                    <ComboBox Width="160" Height="30"
              ItemsSource="{Binding Reasons}"
              SelectedItem="{Binding SelectedReason, Mode=TwoWay}"
              DisplayMemberPath="Display"/>
                </StackPanel>

                <!-- NOTE -->
                <StackPanel>
                    <TextBlock Text="Примечание" Foreground="White"/>
                    <TextBox Text="{Binding Note}" Width="150" Height="30"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource FilterCardStyle}">
            <StackPanel Orientation="Horizontal"
                VerticalAlignment="Center"
                HorizontalAlignment="Left"
               Visibility="{Binding DataContext.CanShowAllExpenses,
                RelativeSource={RelativeSource AncestorType=UserControl},
                Converter={StaticResource BoolToVisibilityConverter}}">

                <TextBlock Text="Период:"
                   FontWeight="SemiBold"
                   Foreground="#2B2B35"
                   VerticalAlignment="Center"
                   Margin="0,0,12,0"/>

                <TextBlock Text="с"
                   VerticalAlignment="Center"
                   Foreground="#444"
                   Margin="0,0,6,0"/>

                <DatePicker SelectedDate="{Binding FromDate, Mode=TwoWay}"
                    Width="140"
                    Height="30"
                    Margin="0,0,12,0"/>

                <TextBlock Text="по"
                   VerticalAlignment="Center"
                   Foreground="#444"
                   Margin="0,0,6,0"/>

                <DatePicker SelectedDate="{Binding ToDate, Mode=TwoWay}"
                    Width="140"
                    Height="30"
                    Margin="0,0,16,0"/>

                <Button Content="Сбросить"
                Width="100"
                Height="30"
                Style="{StaticResource GrayButton}"
                Command="{Binding ClearPeriodCommand}"/>
            </StackPanel>
        </Border>
        <!-- ========================= -->
        <!-- TABLE -->
        <!-- ========================= -->
        <Border Grid.Row="3" Style="{StaticResource GridCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                  ItemsSource="{Binding Rows}"
                  Style="{StaticResource ExpenseGridStyle}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                  Margin="0">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№" Width="50" Binding="{Binding Id}"/>
                        <DataGridTextColumn Header="Дата" Width="110" Binding="{Binding Date, StringFormat=dd.MM.yyyy}"/>
                        <DataGridTextColumn Header="Пользователь" Width="*" Binding="{Binding UserFullName}"/>
                        <DataGridTextColumn Header="СМН" Width="100" Binding="{Binding AmountTjs, StringFormat=N2}"/>
                        <DataGridTextColumn Header="Евро" Width="90" Binding="{Binding AmountEuro, StringFormat=N2}"/>
                        <DataGridTextColumn Header="Причина" Width="180" Binding="{Binding Reason}"/>
                        <DataGridTextColumn Header="Примечание" Width="220" Binding="{Binding Note}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="1"
                Background="#F3F4F8"
                BorderBrush="#E1E3EA"
                BorderThickness="0,1,0,0"
                Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                           Text="{Binding TotalRowsCount}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                        <TextBlock Grid.Column="2"
                           Text="Итого:"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                        <TextBlock Grid.Column="3"
                           Text="{Binding TotalAmountTjs, StringFormat=N2}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                        <TextBlock Grid.Column="4"
                           Text="{Binding TotalAmountEuro, StringFormat=N2}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

    </Grid>

</UserControl>
