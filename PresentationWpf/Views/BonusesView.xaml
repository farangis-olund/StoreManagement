<UserControl x:Class="PresentationWpf.Views.BonusesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1450">

    <UserControl.Resources>

        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#D7D9E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT -->
   
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

           

            <!-- LOWER THAN LEVEL -->
            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                       Text="Клиенты ниже своего уровня"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="0,0,0,8"/>

                    <DataGrid x:Name="DataGrid1" Grid.Row="1" Style="{StaticResource SummaryGrid}"
                      ItemsSource="{Binding LowerThanLevelCustomers}" IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="✓" Width="45">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn IsReadOnly="True" Header="Код клиента" Width="100" Binding="{Binding CustomerId}"/>
                            <DataGridTextColumn IsReadOnly="True" Header="ФИО" Width="*" Binding="{Binding FullName}"/>
                            <DataGridTextColumn IsReadOnly="True" Header="Сумма" Width="100" Binding="{Binding CurrentMonthTotal, StringFormat=N2}"/>
                            <DataGridTextColumn IsReadOnly="True" Header="Текущий" Width="120" Binding="{Binding CurrentLevel}"/>
                            <DataGridTextColumn IsReadOnly="True" Header="Предлагаемый" Width="120" Binding="{Binding SuggestedLevel}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,6,0,10">
                <Button Content="Обновить"
                Style="{StaticResource GrayButton}"
                Width="120"
                Height="30"
                Command="{Binding UpdateLowerLevelsCommand}"/>
                <Button Content="Экпорт..."
                     Style="{StaticResource GrayButton}"
                     Command="{Binding ExportExcelCommand}"
                     CommandParameter="{Binding ElementName=DataGrid1}"
                     Margin="10,0,0,0"
                     MinWidth="70"/>
            </StackPanel>

            <!-- HIGHER THAN LEVEL -->
            <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                       Text="Клиенты выше своего уровня"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="0,0,0,8"/>

                    <DataGrid x:Name="DataGrid2" Grid.Row="1" Style="{StaticResource SummaryGrid}"
                      ItemsSource="{Binding HigherThanLevelCustomers}" IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="✓" Width="45">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn IsReadOnly="True" Header="Код клиента" Width="100" Binding="{Binding CustomerId}"/>
                            <DataGridTextColumn IsReadOnly="True" Header="ФИО" Width="*" Binding="{Binding FullName}"/>
                            <DataGridTextColumn IsReadOnly="True" Header="Сумма" Width="100" Binding="{Binding CurrentMonthTotal, StringFormat=N2}"/>
                            <DataGridTextColumn IsReadOnly="True" Header="Текущий" Width="120" Binding="{Binding CurrentLevel}"/>
                            <DataGridTextColumn IsReadOnly="True" Header="Предлагаемый" Width="120" Binding="{Binding SuggestedLevel}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            
            </Border>

            <StackPanel Grid.Row="4"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,6,0,0">
                
                <Button Content="Обновить"
                Width="120"
                Height="30"
                Style="{StaticResource GrayButton}"
                Command="{Binding UpdateHigherLevelsCommand}"/>

                <Button Content="Экпорт..."
                  Style="{StaticResource GrayButton}"
                  Command="{Binding ExportExcelCommand}"
                  CommandParameter="{Binding ElementName=DataGrid2}"
                  Margin="10,0,0,0"
                  MinWidth="70"/>
            </StackPanel>
        </Grid>

        <!-- RIGHT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- BONUS -->
            <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Бонусы клиентов"
                               FontWeight="Bold"
                               FontSize="14"
                               Margin="0,0,0,8"/>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <TextBlock Text="Бренд:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <ComboBox Width="120"
                                  Height="28"
                                  Margin="0,0,12,0"
                                  ItemsSource="{Binding Brands}"
                                  SelectedItem="{Binding SelectedBrand, Mode=TwoWay}"
                                  IsEditable="True"/>

                        <TextBlock Text="с"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>

                        <DatePicker Width="95"
                                    Height="28"
                                    Margin="0,0,12,0"
                                    SelectedDate="{Binding BonusFromDate, Mode=TwoWay}"
                                    SelectedDateFormat="Short"/>

                        <TextBlock Text="по"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>

                        <DatePicker Width="95"
                                    Height="28"
                                    Margin="0,0,12,0"
                                    SelectedDate="{Binding BonusToDate, Mode=TwoWay}"
                                    SelectedDateFormat="Short"/>

                        <Button Content="Сбросить"
                                Width="100"
                                Height="28"
                                Style="{StaticResource GrayButton}"
                                Command="{Binding ClearBonusPeriodCommand}"/>

                        <Button Content="Экпорт..."
                          Style="{StaticResource GrayButton}"
                          Command="{Binding ExportExcelCommand}"
                          CommandParameter="{Binding ElementName=DataGrid3}"
                          Margin="10,0,0,0"
                          MinWidth="70"/>

                      
                    </StackPanel>

                    <DataGrid x:Name="DataGrid3" Grid.Row="2" Style="{StaticResource SummaryGrid}"
                              ItemsSource="{Binding BrandBonusCustomers}" >
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Код клиента" Width="110" Binding="{Binding CustomerId}"/>
                            <DataGridTextColumn Header="ФИО" Width="*" Binding="{Binding FullName}"/>
                            <DataGridTextColumn  Header="Сумма" Width="120" Binding="{Binding TotalAmount, StringFormat=N2}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- PROMOTION -->
            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                       Text="Акция для клиентов"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="0,0,0,8"/>

                    <DataGrid x:Name="PromotionDataGrid"
                      Grid.Row="1"
                      Style="{StaticResource SummaryGrid}"
                      ItemsSource="{Binding PromotionCustomers}"
                      IsReadOnly="False">

                        <DataGrid.Columns>
                            <DataGridTextColumn IsReadOnly="True" Header="Код клиента" Width="100" Binding="{Binding CustomerId}"/>
                            <DataGridTextColumn IsReadOnly="True" Header="ФИО" Width="*" Binding="{Binding FullName}"/>
                            <DataGridTextColumn IsReadOnly="True" Header="Среднее за 3 мес." Width="130" Binding="{Binding AverageLast3Months, StringFormat=N2}"/>
                            <DataGridTextColumn IsReadOnly="True" Header="Текущий месяц" Width="120" Binding="{Binding CurrentMonthAmount, StringFormat=N2}"/>
                            <DataGridTextColumn IsReadOnly="True" Header="Разница" Width="120" Binding="{Binding Difference, StringFormat=N2}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,6,0,10">

                <Button Content="Экспорт..."
                Width="120"
                Height="30"
                Style="{StaticResource GrayButton}"
                Command="{Binding ExportExcelCommand}"
                CommandParameter="{Binding ElementName=PromotionDataGrid}"/>
            </StackPanel>

            <!-- SHOP BONUS -->
            <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                       Text="Бонус магазина"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="0,0,0,8"/>

                    <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,0,0,8">

                        <TextBlock Text="с"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>

                        <DatePicker Width="95"
                            Height="28"
                            Margin="0,0,12,0"
                            VerticalContentAlignment="Center"
                            SelectedDate="{Binding ShopBonusFromDate, Mode=TwoWay}"
                            SelectedDateFormat="Short"/>

                        <TextBlock Text="по"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>

                        <DatePicker Width="95"
                            Height="28"
                            Margin="0,0,12,0"
                            VerticalContentAlignment="Center"
                            SelectedDate="{Binding ShopBonusToDate, Mode=TwoWay}"
                            SelectedDateFormat="Short"/>
                        <TextBlock Text="Пользователь"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>

                         <ComboBox Width="120"
                          Height="28"
                          Margin="0,0,12,0"
                          ItemsSource="{Binding ShopBonusUsers}"
                          SelectedItem="{Binding SelectedShopBonusUser, Mode=TwoWay}"
                          DisplayMemberPath="UserFullName"
                          IsEditable="True"/>
                        
                        <TextBlock Text="%"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>

                        <TextBox Width="40"
                         Height="28"
                         Margin="0,0,12,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding ShopBonusPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <Button Content="Показать"
                        Width="80"
                        Height="28"
                        Style="{StaticResource GrayButton}"
                        Command="{Binding ShowShopBonusCommand}"/>

                        <Button Content="Сбросить"
                        Width="80"
                        Height="28"
                        Margin="8,0,0,0"
                        Style="{StaticResource GrayButton}"
                        Command="{Binding ClearShopBonusCommand}"/>
                    </StackPanel>

                    <DataGrid x:Name="ShopBonusDataGrid"
                      Grid.Row="2"
                      Style="{StaticResource SummaryGrid}"
                      ItemsSource="{Binding ShopBonusRows}"
                      IsReadOnly="True">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Пользователь" Width="120" Binding="{Binding UserFullName}"/>
                            <DataGridTextColumn Header="Дата" Width="110" Binding="{Binding Date, StringFormat=dd.MM.yyyy}"/>
                            
                            <DataGridTextColumn Header="Кол-во" Width="100" Binding="{Binding TotalQuantity}"/>
                            <DataGridTextColumn Header="Сумма" Width="120" Binding="{Binding TotalAmount, StringFormat=N2}"/>
                            <DataGridTextColumn Header="Бонус" Width="120" Binding="{Binding BonusAmount, StringFormat=N2}"/>
                            
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="3" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="#D7D9E0" BorderThickness="1" Padding="6">
                            <TextBlock Text="Итого:" FontWeight="Bold"/>
                        </Border>

                        <Border Grid.Column="1" BorderBrush="#D7D9E0" BorderThickness="1" Padding="6">
                            <TextBlock Text="{Binding ShopBonusTotalQuantity}" FontWeight="Bold"/>
                        </Border>

                        <Border Grid.Column="2" BorderBrush="#D7D9E0" BorderThickness="1" Padding="6">
                            <TextBlock Text="{Binding ShopBonusTotalAmount, StringFormat=N2}" FontWeight="Bold"/>
                        </Border>

                        <Border Grid.Column="3" BorderBrush="#D7D9E0" BorderThickness="1" Padding="6">
                            <TextBlock Text="{Binding ShopBonusTotalBonus, StringFormat=N2}" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Grid.Row="4"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,6,0,0">

                <Button Content="Экспорт..."
                Width="120"
                Height="30"
                Style="{StaticResource GrayButton}"
                Command="{Binding ExportExcelCommand}"
                CommandParameter="{Binding ElementName=ShopBonusDataGrid}"/>
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>
