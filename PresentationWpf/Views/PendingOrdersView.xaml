<UserControl x:Class="PresentationWpf.Views.PendingOrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="500">

    <Grid Background="White" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Список неотправленных заказов"
                   FontSize="16" FontWeight="Bold" 
                   Margin="10" />

        <!-- DataGrid -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding PendingOrders}" 
                  SelectedItem="{Binding SelectedOrder, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  Margin="0,10,0,10"
                  Style="{StaticResource SummaryGrid}">
            <DataGrid.Columns>
                 <DataGridTextColumn Header="№ Накладной" Binding="{Binding InvoiceNumber}" Width="110"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                <DataGridTextColumn Header="Код клиента" Binding="{Binding CustomerId}" Width="100" ElementStyle="{StaticResource CenterCellStyle}"/>

                <DataGridTemplateColumn Header="Отправлено" Width="*" >
                    
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSent, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
            <Button Content="Обновить" 
                    Command="{Binding UpdateCommand}" 
                    Style="{StaticResource GrayButton}" 
                    Width="100" Height="30" Margin="5"/>
           
        </StackPanel>
    </Grid>
</UserControl>
