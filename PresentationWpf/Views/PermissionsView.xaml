<UserControl x:Class="PresentationWpf.Views.PermissionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
              xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:local="clr-namespace:PresentationWpf.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="400">

    <UserControl.Resources>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="#EFEFEF"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="4"
                      Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#333"/>
        </Style>

        <!-- DELETE BUTTON (RED) -->
        <Style x:Key="DeleteIconButton" BasedOn="{StaticResource IconButton}" TargetType="Button">
            <Setter Property="Background" Value="#C62828"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#8E0000"/>
        </Style>

    </UserControl.Resources>

    <Border Background="#F7F7F7"
            BorderBrush="#DDD"
            BorderThickness="1"
            CornerRadius="8"
            Padding="15">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER + ADD BUTTON -->
            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Управление правами"
                           FontSize="22"
                           FontWeight="Bold"
                           DockPanel.Dock="Left"/>

                
            </DockPanel>

            <!-- PERMISSIONS GRID -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Permissions}"
                     
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      Style="{StaticResource SummaryGrid}"
                      Background="White"
                      BorderBrush="#DDD"
                      BorderThickness="1"
                      RowHeight="32"
                      ColumnHeaderHeight="30"
                      Margin="0,0,0,15">

                <DataGrid.Columns>

                    <!-- KEY COLUMN -->
                    <DataGridTemplateColumn Header="Ключ" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <!-- Display -->
                                    <TextBlock Text="{Binding Key}"
                           Visibility="{Binding IsEditing,
                               Converter={StaticResource BoolToVisibilityConverter2},
                               ConverterParameter=Invert}" />

                                    <!-- Edit -->
                                    <TextBox Text="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="4"
                         Visibility="{Binding IsEditing,
                             Converter={StaticResource BoolToVisibilityConverter2}}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Описание" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <!-- DISPLAY MODE -->
                                    <TextBlock Text="{Binding Description}"
                           Visibility="{Binding IsEditing,
                               Converter={StaticResource BoolToVisibilityConverter2},
                               ConverterParameter=Invert}" />

                                    <!-- EDIT MODE -->
                                    <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="4"
                         Visibility="{Binding IsEditing,
                             Converter={StaticResource BoolToVisibilityConverter2}}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>


                    <!-- ACTIONS COLUMN -->
                    <DataGridTemplateColumn Header="Действия" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">

                                    <!-- EDIT BUTTON -->
                                    <Button Command="{Binding DataContext.EditPermissionCommand,
                                      RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                                         Width="30"
                                         Height="28"
                                           
                                            CommandParameter="{Binding}"
                                        Style="{StaticResource IconButton}">
                                        <fa:ImageAwesome Icon="Pencil"
                                           Width="12"
                                           Height="12"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                                    </Button>

                                    <!-- DELETE BUTTON -->
                                    <Button Command="{Binding DataContext.DeletePermissionCommand,
                                      RelativeSource={RelativeSource FindAncestor, AncestorType=UserControl}}"
                                        Width="30"
                                         Height="28"
                                         
                                            CommandParameter="{Binding}"
                                        Style="{StaticResource DeleteIconButton}"
                                        Margin="5,0,0,0">
                                        <fa:ImageAwesome Icon="Trash"
                                          Width="12"
                                          Height="12"
                                          Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>

                                    </Button>

                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>


            </DataGrid>

            <Button Grid.Row="2"
                Width="160"
                Height="30"
                Margin="10,0,0,0"
                HorizontalAlignment="left"
                Style="{StaticResource GrayButton}"
                Command="{Binding AddPermissionCommand}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <fa:ImageAwesome Icon="Plus" Width="14" Height="14" Margin="0,0,6,0"/>
                    <TextBlock Text="Добавить право" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- SAVE BUTTON -->
            <Button Grid.Row="2"
                Width="160"
                Height="32"
                HorizontalAlignment="Right"
                Style="{StaticResource GrayButton}"
                Command="{Binding SaveCommand}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <fa:ImageAwesome Icon="Save" Width="16" Height="16" Margin="0,0,6,0"/>
                    <TextBlock Text="Сохранить" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>


        
        </Grid>
    </Border>

</UserControl>
