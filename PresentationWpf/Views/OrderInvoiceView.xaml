<UserControl x:Class="PresentationWpf.Views.OrderInvoiceView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:PresentationWpf.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:OrderInvoiceViewModel}"
             mc:Ignorable="d"
             Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">

    <!-- ===== Styles ===== -->
    <UserControl.Resources>
        <Style x:Key="Hdr" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RightText" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style x:Key="Cell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="4,2"/>
        </Style>

        <Style x:Key="ColHdr" TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- underline-only border -->
        <Style x:Key="ThinUnderline" TargetType="Border">
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="3,1"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- box border -->
        <Style x:Key="ThinBox" TargetType="Border">
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="3,1"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

       

    </UserControl.Resources>

    <!-- ===== Page container: keeps A4 look and centers it ===== -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR (fixed) -->
        <Border x:Name="TopBar" Grid.Row="0"
                Background="White"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel LastChildFill="False">
               
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource GreenButton}"
                        Content="Печать"
                        Command="{Binding PrintCommand}"
                         CommandParameter="{Binding ElementName=Root}" 
                        ToolTip="Печать (Ctrl+P)"/>

                <Button DockPanel.Dock="Left" Margin="10,0,10,0"
                     Style="{StaticResource GrayButton}"
                     Content="Назад"
                     Command="{Binding BackToOrderCommand}"
                     />
            </DockPanel>
        </Border>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Border x:Name="InvoicePage"
                    Width="794" Height="1123"
                    Background="White"
                    HorizontalAlignment="Center" VerticalAlignment="Top"
                    Margin="20"
                    BorderBrush="#DDDDDD" BorderThickness="1" Padding="18">
                <!-- ===== Invoice content ===== -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- header -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <!-- client/meta -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <!-- title -->
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <!-- grid -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <!-- totals -->
                        <RowDefinition Height="*"/>
                        <!-- signatures/white space -->
                    </Grid.RowDefinitions>

                    <!-- ===== HEADER ===== -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="АВТО-ЗАПЧАСТИ" FontSize="22" FontWeight="Bold"/>
                            <Rectangle Height="1" Fill="Gray" Margin="0,6,220,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="Дата:" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding InvoiceDate, StringFormat={}{0:dd.MM.yyyy}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- ===== CLIENT / META ===== -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 1 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="95"/>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="85"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="ФИО клиента:" Style="{StaticResource Hdr}" Margin="0,0,5,0"/>
                            <Border Grid.Column="1" Style="{StaticResource ThinUnderline}">
                                <TextBlock Text="{Binding CustomerName}"/>
                            </Border>

                            <TextBlock Grid.Column="2" Text="Обл:" Style="{StaticResource Hdr}" HorizontalAlignment="Right" Margin="8,0,5,0"/>
                            <Border Grid.Column="3" Style="{StaticResource ThinUnderline}"/>

                            <TextBlock Grid.Column="4" Text="Курс валюты" Style="{StaticResource Hdr}" HorizontalAlignment="Left" Margin="10,0,0,0" Width="78" Grid.ColumnSpan="2"/>
                            <Border Grid.Column="5" Style="{StaticResource ThinUnderline}" Margin="10,0,0,0">
                                <TextBlock Text="{Binding Rate}" HorizontalAlignment="Right"/>
                            </Border>
                        </Grid>

                        <!-- Row 2 -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <!-- label "Город:" -->
                                <ColumnDefinition Width="45"/>
                                <!-- city value -->
                                <ColumnDefinition Width="100"/>

                                <!-- label "Адрес:" -->
                                <ColumnDefinition Width="55"/>
                                <!-- address value (flexes) -->
                                <ColumnDefinition Width="*"/>

                                <!-- label "Контакты:" -->
                                <ColumnDefinition Width="75"/>
                                <!-- phone value -->
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Город:" Style="{StaticResource Hdr}" Margin="0,0,5,0"/>
                            <Border Grid.Column="1" Style="{StaticResource ThinUnderline}">
                                <TextBlock Text="{Binding CustomerCity}"/>
                            </Border>

                            <TextBlock Grid.Column="2" Text="Адрес:" Style="{StaticResource Hdr}" HorizontalAlignment="Right" Margin="8,0,5,0"/>
                            <Border Grid.Column="3" Style="{StaticResource ThinUnderline}">
                                <TextBlock Text="{Binding CustomerAddress}"/>
                            </Border>

                            <TextBlock Grid.Column="4" Text="Контакты:" Style="{StaticResource Hdr}" HorizontalAlignment="Right" Margin="8,0,5,0"/>
                            <Border Grid.Column="5" Style="{StaticResource ThinUnderline}">
                                <TextBlock Text="{Binding CustomerPhoneNumber}" />
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ===== TITLE ===== -->
                    <StackPanel Grid.Row="4" HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock Text="Товарный чек №" Margin="0,0,6,0" FontSize="14"/>
                        <Border Style="{StaticResource ThinUnderline}" MinWidth="80" Padding="10,1">
                            <TextBlock Text="{Binding InvoiceNumber}" Style="{StaticResource Hdr}"/>
                        </Border>
                    </StackPanel>

                    <!-- ===== GRID ===== -->
                    <DataGrid Grid.Row="6"
                      ItemsSource="{Binding OrderDetails}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      RowHeaderWidth="0" FontSize="12"
                      BorderThickness="1" BorderBrush="Black"
                      SnapsToDevicePixels="True" UseLayoutRounding="True"
                      ColumnHeaderHeight="26" RowHeight="24"
                      HorizontalGridLinesBrush="#66000000"
                      VerticalGridLinesBrush="#66000000"
                      EnableRowVirtualization="False"
                      EnableColumnVirtualization="False"
                      ScrollViewer.CanContentScroll="False">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Padding" Value="2"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <!-- your columns -->
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Артикул" Binding="{Binding ArticleNumber}" Width="120"/>
                            <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Бренд" Binding="{Binding BrandName}" Width="80"/>
                            <DataGridTextColumn Header="Марка" Binding="{Binding Marka}" Width="90"/>
                            <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="120"/>
                            <DataGridTextColumn Header="Кол" Binding="{Binding Quentity}" Width="50"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:N2}}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding Total, StringFormat={}{0:N2}}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Место" Binding="{Binding WarehousePlace}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>


                    <!-- ===== TOTALS ===== -->
                    <Grid Grid.Row="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row count & sum -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock>
                                <Run Text="Всего наименований: "/>
                                <Run Text="{Binding RowCount}" FontWeight="SemiBold"/>

                            </TextBlock>

                            <TextBlock Margin="12,0,0,0">
                                 <Run Text="Итого: "/>
                                <Run Text="{Binding TotalSum, StringFormat={}{0:N2}}" FontWeight="SemiBold"/>
                            </TextBlock>
                             <!-- Sum in words -->
                            <TextBlock Grid.Row="2" Text="{Binding TotalSumInWords}" Margin="12,0,0,0"/>
                        </StackPanel>
 
                        <!-- Totals row -->
                        <Grid Grid.Row="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- labels -->
                                <RowDefinition Height="26"/>
                                <!-- boxes -->
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>

                                <!-- caption -->
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>

                            <!-- small labels above boxes -->
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Итоги продаж" FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Старый долг"  FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="ПогДолг"      FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="Оплачено"     FontSize="10" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="6" Text="Остаток"      FontSize="10" HorizontalAlignment="Center"/>


                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ThinBox}">
                                <TextBlock Text="{Binding TotalSum, StringFormat={}{0:N2}}" Style="{StaticResource RightText}"/>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource ThinBox}">
                                <TextBlock Text="{Binding OldDebt, StringFormat={}{0:N2}}" Style="{StaticResource RightText}"/>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="3" Style="{StaticResource ThinBox}">
                                <TextBlock Text="{Binding CurrentPayment, StringFormat={}{0:N2}}" Style="{StaticResource RightText}"/>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="4" Style="{StaticResource ThinBox}">
                                <TextBlock Text="{Binding AllTotals, StringFormat={}{0:N2}}" Style="{StaticResource RightText}"/>
                            </Border>

                            <!-- spacer col 5 -->

                            <Border Grid.Row="1" Grid.Column="6" Style="{StaticResource ThinBox}">
                                <TextBlock Text="{Binding Total, StringFormat={}{0:N2}}" Style="{StaticResource RightText}"/>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ===== Signatures ===== -->
                    <UniformGrid Grid.Row="9" Columns="3" Margin="0,18,0,0">
                        <TextBlock Text="Разрешено_____________________" />
                        <TextBlock Text="Отпустил______________________" />
                        <TextBlock Text="Получил______________________" />
                    </UniformGrid>
                </Grid>
            </Border>
        </ScrollViewer>
        
    </Grid>
</UserControl>
