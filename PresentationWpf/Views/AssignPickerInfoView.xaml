<UserControl x:Class="PresentationWpf.Views.AssignPickerInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="900">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="СБОРЩИКИ" FontSize="18" Margin="0,0,0,10"/>
        <!-- ===== HEADER BUTTONS ===== -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
            <Button Content="Добавить"
                    Command="{Binding AddCommand}"
                    Style="{StaticResource GrayButton}"
                    Width="100"
                    Margin="0,0,5,0"/>
            <Button Content="Изменить"
                    Command="{Binding UpdateCommand}"
                    Style="{StaticResource GrayButton}"
                    Width="100"
                    Margin="0,0,5,0"/>
            <Button Content="Удалить"
                    Command="{Binding DeleteCommand}"
                    Style="{StaticResource GrayButton}"
                    Width="100"
                    Margin="0,0,5,0"/>
            <Button Content="Сохранить"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource GrayButton}"
                    Width="100"/>
        </StackPanel>

        <!-- ===== INPUT FIELDS ===== -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                <TextBlock Text="Код комплектовщика" FontSize="12" Margin="0,0,0,2"/>
                <TextBox  FontSize="14" Text="{Binding SelectedStorekeeper.Id, Mode=TwoWay}"
                         IsReadOnly="True" Height="30" Background="#F0F0F0"        
                            BorderBrush="#CCC"
                            Foreground="Black"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,5,0">
                <TextBlock Text="ФИО" FontSize="12" Margin="0,0,0,2"/>
                <TextBox  FontSize="14" Text="{Binding SelectedStorekeeper.FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="0,0,5,0">
                <TextBlock Text="Телефон" FontSize="12" Margin="0,0,0,2"/>
                <TextBox FontSize="14" Text="{Binding SelectedStorekeeper.Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
            </StackPanel>

            <StackPanel Grid.Column="3">
                <TextBlock Text="Активен" FontSize="12" Margin="0,0,0,2" HorizontalAlignment="Center"/>
                <CheckBox IsChecked="{Binding SelectedStorekeeper.Active, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ===== DATAGRID ===== -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Storekeepers}"
                  Style="{StaticResource SummaryGrid}"
                  SelectedItem="{Binding SelectedStorekeeper, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  Margin="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код" Binding="{Binding Id}" Width="*"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="2*"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="1*"/>
                <DataGridCheckBoxColumn Header="Активен" Binding="{Binding Active}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
