<UserControl x:Class="PresentationWpf.Views.PriceLevelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PresentationWpf.Views" 
             xmlns:viewmodels="clr-namespace:PresentationWpf.ViewModels" 
            
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== TITLE ===== -->
        <TextBlock Grid.Row="0" Text="УРОВНИ ЦЕН"
                   FontSize="18" FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <!-- ===== BUTTON PANEL ===== -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,10">

            <Button Content="Добавить"
                    Command="{Binding AddCommand}"
                    Style="{StaticResource GrayButton}"
                    Width="100"
                    Margin="0,0,5,0"/>

            <Button Content="Изменить"
                    Command="{Binding UpdateCommand}"
                    Style="{StaticResource GrayButton}"
                    Width="100"
                    Margin="0,0,5,0"/>

            <Button Content="Удалить"
                    Command="{Binding DeleteCommand}"
                    Style="{StaticResource GrayButton}"
                    Width="100"
                    Margin="0,0,5,0"/>

            <Button Content="Сохранить"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource GrayButton}"
                    Width="100"/>
        </StackPanel>

        <!-- ===== INPUT FORM ===== -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="150"/>
               
            </Grid.ColumnDefinitions>

            <!-- LEVEL -->
            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                <TextBlock Margin="0,0,0,2">
                   <Run Text="Уровень" Foreground="Black"/>
                   <Run Text="*" Foreground="Red"/>
                </TextBlock>
                <TextBox FontSize="14" Height="30"
                         Text="{Binding SelectedPriceLevel.Level, Mode=TwoWay,
                         UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
           

            <!-- MIN LIMIT -->
            <StackPanel Grid.Column="1" Margin="0,0,5,0">
                <TextBlock Text="Мин. лимит" FontSize="12" Margin="0,0,0,2"/>
                <TextBox FontSize="14" Height="30"
                         Text="{Binding SelectedPriceLevel.MinLimit, Mode=TwoWay}"/>
            </StackPanel>

            <!-- MAX LIMIT -->
            <StackPanel Grid.Column="2" Margin="0,0,5,0">
                <TextBlock Text="Макс. лимит" FontSize="12" Margin="0,0,0,2"/>
                <TextBox FontSize="14" Height="30"
                         Text="{Binding SelectedPriceLevel.MaxLimit, Mode=TwoWay}"/>
            </StackPanel>

        
        </Grid>

        <!-- ===== DATAGRID ===== -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding PriceLevels}"
                  SelectedItem="{Binding SelectedPriceLevel, Mode=TwoWay}"
                  Style="{StaticResource SummaryGrid}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  Margin="0">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Уровень" Binding="{Binding Level}" Width="*"/>
                <DataGridTextColumn Header="Мин" Binding="{Binding MinLimit}" Width="*"/>
                <DataGridTextColumn Header="Макс" Binding="{Binding MaxLimit}" Width="*"/>
            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</UserControl>
