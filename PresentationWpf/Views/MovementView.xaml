<UserControl x:Class="PresentationWpf.Views.MovementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>     <!-- Header with close button -->
            <RowDefinition Height="*"/>         <!-- Content (left + right panel) -->
            <RowDefinition Height="2*"/>        <!-- Bottom inventory list -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,15">
            <TextBlock Text="ДВИЖЕНИЯ ТОВАРОВ"
                       FontWeight="Bold"
                       FontSize="18"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>
            <Button Content="X"
                    Style="{StaticResource CloseButton}"
                    Command="{Binding CloseCommand}"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right"/>
        </DockPanel>

        <!-- Left Panel -->
        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Vertical" Margin="0,0,10,0">
            <!-- Приход / Расход -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <RadioButton Content="приход"
                             GroupName="MovementType"
                             IsChecked="{Binding IsIncoming, Mode=TwoWay}"
                             Margin="0,0,10,0"/>
                <RadioButton Content="расход"
                             GroupName="MovementType"
                             IsChecked="{Binding IsOutgoing, Mode=TwoWay}"/>
            </StackPanel>

            <!-- Артикул + Кол-во -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Артикул:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="ArticleComboBox" ItemsSource="{Binding Articles}" Height="30"
                          SelectedItem="{Binding SelectedArticle, Mode=TwoWay}" VerticalContentAlignment="Center" FontSize="14"
                          Width="180" IsEditable="True"  KeyDown="ArticleComboBox_KeyDown"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Кол-во:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="QuantityTextBox" Text="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="80"
                         KeyDown="QuantityTextBox_KeyDown"/>

                <TextBlock Text="БД:" VerticalAlignment="Center" Margin="10,0,5,10"/>
                <TextBox Text="{Binding DbQuantity}"  IsReadOnly="True" Width="80"/>
            </StackPanel>

            <!-- Date -->
            <DatePicker SelectedDate="{Binding MovementDate}" Height="30" VerticalContentAlignment="Center" FontSize="14" Margin="0,0,0,10"/>

            <!-- Buttons -->
            <StackPanel Orientation="Vertical">
                <Button Content="Приход (*.exlx)" Style="{StaticResource GrayButton}" Width="240"
                        Command="{Binding ImportReceiptFromExcelCommand}"
                        Margin="0,0,0,10"/>
                <Button Content="Погашение долгов (*.exlx)" Style="{StaticResource GrayButton}" Width="240"
                        Command="{Binding ImportWriteOffFromExcelCommand}"
                        Margin="0,0,0,10"/>
                <Button Content="Товары несуществующие в БД" Style="{StaticResource GrayButton}" Width="240"
                        Command="{Binding ShowArticlesCommand}"
                        IsEnabled="{Binding HasImportErrors}"
                        Margin="0,0,0,10"/>
            </StackPanel>
        </StackPanel>

        <!-- Right Panel: Список изменений -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>     <!-- Header & Buttons -->
                <RowDefinition Height="*"/>        <!-- DataGrid -->
            </Grid.RowDefinitions>

            <!-- Header + Buttons -->
            <DockPanel Grid.Row="0" Margin="0,0,0,5" Background="#EEE">
                <TextBlock Text="Список изменений"
                           FontWeight="Bold"
                           FontSize="14"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Content="Печать" Command="{Binding PrintCommand}" Margin="5,0" Style="{StaticResource GreenButton}" Height="30"/>
                    <Button Content="Очистить" Command="{Binding ClearCommand}" Margin="5,0" Style="{StaticResource GrayButton}"/>
                </StackPanel>
            </DockPanel>

            <!-- DataGrid -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding MovementChanges}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      Style="{StaticResource SummaryGrid}"
                      Margin="0,0,0,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="артикул" Binding="{Binding Article}" Width="200"/>
                    <DataGridTextColumn Header="кол" Binding="{Binding QuantityDb}" Width="60" ElementStyle="{StaticResource NumberCellStyle}"/>
                    <DataGridTextColumn Header="приход/расход" Binding="{Binding Quantity}" Width="120" ElementStyle="{StaticResource NumberCellStyle}"/>
                    <DataGridTextColumn Header="итого" Binding="{Binding Total}" Width="100" ElementStyle="{StaticResource NumberCellStyle}"/>
                    <DataGridTextColumn Header="место" Binding="{Binding Location}" Width="100" ElementStyle="{StaticResource CenterCellStyle}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Нижний DataGrid (inventory list) -->
        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Товары (остатки на складе)"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="0,0,0,5"/>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Inventory}"
                      Style="{StaticResource SummaryGrid}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="артикул" Binding="{Binding ArticleNumber}" Width="140"/>
                    <DataGridTextColumn Header="наименование" Binding="{Binding ProductName}" Width="150"/>
                    <DataGridTextColumn Header="группа" Binding="{Binding GroupName}" Width="100"/>
                    <DataGridTextColumn Header="бренд" Binding="{Binding BrandName}" Width="100"/>
                    <DataGridTextColumn Header="марка" Binding="{Binding Marka}" Width="120"/>
                    <DataGridTextColumn Header="модель" Binding="{Binding Model}" Width="*"/>
                    <DataGridTextColumn Header="кол" Binding="{Binding Quentity}" Width="80" ElementStyle="{StaticResource NumberCellStyle}"/>
                      <DataGridTextColumn Header="место" Binding="{Binding WarehousePlace}" Width="80" ElementStyle="{StaticResource CenterCellStyle}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
