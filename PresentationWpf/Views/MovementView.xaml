<UserControl x:Class="PresentationWpf.Views.MovementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <!-- Left Panel -->
        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical" Margin="0,0,10,0">
            <!-- Приход / Расход -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <RadioButton Content="приход"
                             GroupName="MovementType"
                             IsChecked="{Binding IsIncoming, Mode=TwoWay}"
                             Margin="0,0,10,0"/>
                <RadioButton Content="расход"
                             GroupName="MovementType"
                             IsChecked="{Binding IsOutgoing, Mode=TwoWay}"/>
            </StackPanel>

            <!-- Артикул + Кол-во -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Артикул:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox ItemsSource="{Binding Articles}" Height="30"
                          SelectedItem="{Binding SelectedArticle}"
                          Width="180"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Кол-во:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox Text="{Binding Quantity, Mode=TwoWay}" Width="80"/>
                <TextBlock Text="БД:" VerticalAlignment="Center" Margin="10,0,5,10"/>
                <TextBox Text="{Binding DbQuantity}" IsReadOnly="True" Width="80"/>
            </StackPanel>

            <!-- Date -->
            <DatePicker SelectedDate="{Binding MovementDate}" Height="30" Margin="0,20,0,10"/>

            <!-- Buttons -->
            <StackPanel Orientation="Vertical" Margin="0,0,0,0">
                <Button Content="Приход"
                        Command="{Binding AddIncomingCommand}"
                        Margin="0,0,0,10"/>
                <Button Content="Погашение долгов"
                        Command="{Binding RepayDebtCommand}"
                        Margin="0,0,0,10"/>
                <Button Content="Список артикулов несущихся в БД"
                        Command="{Binding ShowArticlesCommand}"
                        Margin="0,0,0,10"/>
            </StackPanel>
        </StackPanel>

        <!-- Right Panel: Список изменений -->
        <Grid Grid.Row="0" Grid.Column="1" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header & Buttons -->
                <RowDefinition Height="*"/>
                <!-- DataGrid -->
            </Grid.RowDefinitions>

            <!-- Header + Buttons -->
            <DockPanel Grid.Row="0" Margin="0,0,0,5" Background="#EEE" >
                <!-- Section title -->
                <TextBlock Text="Список изменений"
                           FontWeight="Bold"
                           FontSize="14"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>

                <!-- Buttons aligned to right -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Content="Закрыть" Command="{Binding CloseCommand}" Margin="5,0"/>
                    <Button Content="Очистить" Command="{Binding ClearCommand}" Margin="5,0"/>
                    <Button Content="Печать" Command="{Binding PrintCommand}" Margin="5,0"/>
                </StackPanel>
            </DockPanel>

            <!-- DataGrid -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding MovementChanges}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      Margin="0,0,0,10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="артикул" Binding="{Binding Article}" Width="200"/>
                    <DataGridTextColumn Header="кол-во" Binding="{Binding Quantity}" Width="60"/>
                    <DataGridTextColumn Header="приход/расход" Binding="{Binding Type}" Width="100"/>
                    <DataGridTextColumn Header="итого" Binding="{Binding Total}" Width="100"/>
                    <DataGridTextColumn Header="место" Binding="{Binding Location}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Нижний DataGrid (inventory list) -->
        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Section title -->
            <TextBlock Text="Товары (остатки на складе)"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="0,0,0,5"/>

            <!-- Inventory DataGrid -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Inventory}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="артикул" Binding="{Binding Article}" Width="100"/>
                    <DataGridTextColumn Header="наименование" Binding="{Binding ProductName}" Width="150"/>
                    <DataGridTextColumn Header="группа" Binding="{Binding Group}" Width="80"/>
                    <DataGridTextColumn Header="бренд" Binding="{Binding Brand}" Width="80"/>
                    <DataGridTextColumn Header="марка" Binding="{Binding Marka}" Width="100"/>
                    <DataGridTextColumn Header="модель" Binding="{Binding Model}" Width="100"/>
                    <DataGridTextColumn Header="количество" Binding="{Binding Quantity}" Width="80"/>
                    <DataGridTextColumn Header="розн. цена" Binding="{Binding RetailPrice}" Width="80"/>
                    <DataGridTextColumn Header="опт. цена" Binding="{Binding WholesalePrice}" Width="80"/>
                    <DataGridTextColumn Header="место" Binding="{Binding Location}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
