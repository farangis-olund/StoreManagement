<UserControl x:Class="PresentationWpf.Views.CustomerSalesPaymentsReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PresentationWpf.Views"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <!-- ===================== -->
        <!-- FILTER PANEL -->
        <!-- ===================== -->
        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,10"
                    VerticalAlignment="Center">

            <TextBlock Text="С:" Margin="0,0,5,0"/>
            <DatePicker SelectedDate="{Binding FromDate}" Width="120" Height="30" FontSize="13" Margin="0,0,15,0"/>

            <TextBlock Text="По:" Margin="0,0,5,0"/>
            <DatePicker SelectedDate="{Binding ToDate}" Width="120" Height="30" FontSize="13" Margin="0,0,15,0"/>

            <TextBlock Text="Регион:" Margin="0,0,5,0"/>
            <ComboBox Width="120" Height="30" FontSize="13"
                      ItemsSource="{Binding Regions}"
                      SelectedItem="{Binding SelectedRegion}"
                      IsEditable="True"
                      Margin="0,0,15,0"/>

            <TextBlock Text="Фирма:" Margin="0,0,5,0"/>
            <ComboBox Width="120" Height="30" FontSize="13"
                      ItemsSource="{Binding Firmas}"
                      SelectedItem="{Binding SelectedFirma}"
                      IsEditable="True"
                      Margin="0,0,20,0"/>

            <CheckBox Content="С учетом даты"
                      IsChecked="{Binding UseDateGrouping}"
                      VerticalAlignment="Center"/>

        </StackPanel>

      
        <!-- TABLE -->
        <DataGrid Grid.Row="2"
          ItemsSource="{Binding Rows}"
          AutoGenerateColumns="False"
          IsReadOnly="True"
          Style="{StaticResource SummaryGrid}">


            <DataGrid.Columns>
                <DataGridTextColumn Header="Код" Width="100" Binding="{Binding CustomerCode}"/>
                <DataGridTextColumn Header="ФИО" Width="200" Binding="{Binding FullName}"/>
                <DataGridTextColumn Header="Продажа" Binding="{Binding Sales}"/>
                <DataGridTextColumn Header="Платежи" Binding="{Binding Payments}"/>
            </DataGrid.Columns>

        </DataGrid>

        <!-- CHART -->
        <lvc:CartesianChart Grid.Row="3"
                    Series="{Binding SeriesCollection}"
                    AxisX="{Binding AxisX}"
                    LegendLocation="Right">

            <lvc:CartesianChart.AxisY>
                <lvc:Axis Title="Сумма"
                  LabelFormatter="{Binding Formatter}"/>
            </lvc:CartesianChart.AxisY>

        </lvc:CartesianChart>

    </Grid>
</UserControl>
