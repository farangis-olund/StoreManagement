<UserControl x:Class="PresentationWpf.Views.UserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="900">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Панель кнопок -->
            <RowDefinition Height="Auto"/>
            <!-- Поля для ввода -->
            <RowDefinition Height="*"/>
            <!-- Таблица -->
        </Grid.RowDefinitions>

        <!-- 🔵 Кнопки управления (сверху) -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Добавить"  Style="{StaticResource GrayButton}" Width="100" Margin="2" Command="{Binding AddUserAsyncCommand}"/>
            <Button Content="Изменить" Style="{StaticResource GrayButton}" Width="100" Margin="2" Command="{Binding UpdateUserAsyncCommand}"/>
            <Button Content="Удалить" Style="{StaticResource GrayButton}" Width="100" Margin="2" Command="{Binding DeleteUserAsyncCommand}"/>
        </StackPanel>

        <!-- 🟣 Форма добавления / редактирования -->
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10">
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Имя пользователя"/>
                <TextBox Width="120" Height="30" VerticalContentAlignment="Center" FontSize="15" Text="{Binding CurrentUser.UserName, Mode=TwoWay}"/>
            </StackPanel>

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Имя"/>
                <TextBox Width="120" Height="30" VerticalContentAlignment="Center"  FontSize="15" Text="{Binding CurrentUser.FirstName, Mode=TwoWay}"/>
            </StackPanel>

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Фамилия"/>
                <TextBox Width="120" Height="30" VerticalContentAlignment="Center"  FontSize="15" Text="{Binding CurrentUser.LastName, Mode=TwoWay}"/>
            </StackPanel>

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Электронная почта"/>
                <TextBox Width="160" Height="30" VerticalContentAlignment="Center"  FontSize="15" Text="{Binding CurrentUser.Email, Mode=TwoWay}"/>
            </StackPanel>

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Телефон"/>
                <TextBox Width="120" Height="30" VerticalContentAlignment="Center"  FontSize="15" Text="{Binding CurrentUser.PhoneNumber, Mode=TwoWay}"/>
            </StackPanel>

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Пароль"/>
                <TextBox Width="120" Height="30" FontSize="15" Text="{Binding CurrentUser.Password, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Роль"/>
                <ComboBox Width="260" Height="30" VerticalContentAlignment="Center"  FontSize="15"
                          ItemsSource="{Binding Roles}"
                          DisplayMemberPath="RoleName"
                          SelectedItem="{Binding SelectedRole, Mode=TwoWay}"/>
            </StackPanel>
        </StackPanel>

        <!-- 🟢 Таблица пользователей -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Users}"
                   Style="{StaticResource SummaryGrid}"
                  SelectedItem="{Binding CurrentUser, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя пользователя" Binding="{Binding UserName}" Width="150"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="150"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="150"/>
                <DataGridTextColumn Header="Эл. почта" Binding="{Binding Email}" Width="150"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding PhoneNumber}" Width="150"/>

                <!-- Колонка выбора роли -->
                <DataGridTemplateColumn Header="Роль" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding UserRoles[0].Role.RoleName}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.Roles, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      DisplayMemberPath="RoleName"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding UserRoles[0].RoleId, Mode=TwoWay}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
