<UserControl x:Class="PresentationWpf.Views.OfficialSalesSummaryReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="900">
    <Grid x:Name="RootVisual" Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="0,0,0,10">
            <TextBlock Text="Период:"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Margin="0,0,8,0"/>

            <TextBlock Text="с"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>

            <DatePicker SelectedDate="{Binding FromDate, Mode=TwoWay}"
                        SelectedDateFormat="Short"
                        Width="130"
                        Height="30"
                        Margin="0,0,10,0"/>

            <TextBlock Text="по"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>

            <DatePicker SelectedDate="{Binding ToDate, Mode=TwoWay}"
                        SelectedDateFormat="Short"
                        Width="130"
                        Height="30"
                        Margin="0,0,16,0"/>

            <Button Content="Отчет"
                    Command="{Binding LoadCommand}"
                    Style="{StaticResource GrayButton}"
                    Width="100"
                    Height="32"
                    Margin="0,0,8,0"/>

            <Button Content="Печать"
                    Command="{Binding PrintCommand}"
                    CommandParameter="{Binding ElementName=RootVisual}"
                    Style="{StaticResource GrayButton}"
                    Width="100"
                    Height="32"
                    Margin="0,0,8,0"/>

            <Button Content="Экспорт"
                    Command="{Binding ExportCommand}"
                    CommandParameter="{Binding ElementName=ReportGrid}"
                    Style="{StaticResource GrayButton}"
                    Width="100"
                    Height="32"/>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="ИТОГИ ПО ПРОДАЖАМ"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <DataGrid x:Name="ReportGrid"
                  Grid.Row="2"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Style="{StaticResource SummaryGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата"
                                    Binding="{Binding Date, StringFormat=d}"
                                    Width="90"/>
                <DataGridTextColumn Header="Накладная"
                                    Binding="{Binding OrderId}"
                                    Width="110"/>
                <DataGridTextColumn Header="ФИО клиента"
                                    Binding="{Binding CustomerFullName}"
                                    Width="180"/>
                <DataGridTextColumn Header="Артикул"
                                    Binding="{Binding ArticleNumber}"
                                    Width="110"/>
                <DataGridTextColumn Header="Наименование"
                                    Binding="{Binding ProductName}"
                                    Width="220"/>
                <DataGridTextColumn Header="Бренд"
                                    Binding="{Binding BrandName}"
                                    Width="110"/>
                <DataGridTextColumn Header="Марка"
                                    Binding="{Binding Marka}"
                                    Width="110"/>
                <DataGridTextColumn Header="Модель"
                                    Binding="{Binding Model}"
                                    Width="140"/>
                <DataGridTextColumn Header="Кол-во"
                                    Binding="{Binding Quantity}"
                                    Width="80"/>
                <DataGridTextColumn Header="Сумма СМН"
                                    Binding="{Binding TotalSmn, StringFormat=N2}"
                                    Width="110"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
