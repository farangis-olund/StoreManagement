<UserControl x:Class="PresentationWpf.Views.TransferReceiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="900">
    <UserControl.Resources>
       
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Top buttons -->
            <RowDefinition Height="*"/>
            <!-- Main content area -->
        </Grid.RowDefinitions>

        <!-- === Header with Close Button === -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="ПОЛУЧЕНИЕ И ПЕРЕДАЧА ТОВАРОВ"
                       FontWeight="Bold"
                       FontSize="18"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>
            <Button Content="X"
                    Style="{StaticResource CloseButton}"
                    Command="{Binding CloseCommand}"
                    DockPanel.Dock="Right"
                    HorizontalAlignment="Right"/>
        </DockPanel>

        <!-- === Top two buttons (fixed colors) === -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="left"
                    Margin="0,10,0,0">
            <ToggleButton Content="ПРИХОД"
                    Style="{StaticResource TabButton}"
                    Width="260" Height="45"
                    FontWeight="Bold"
                    Background="#C2E6ED"
                    Command="{Binding SelectIncomingCommand}"
                    Margin="0,0"/>
            <ToggleButton Content="РАСХОД"
                    Style="{StaticResource TabButton}"
                    Width="260" Height="45"
                    FontWeight="Bold"
                    Background="#8EBACD"
                    Command="{Binding SelectOutgoingCommand}"
                    Margin="5,0"/>
        </StackPanel>

        <!-- === Main content area with changing background === -->
        <Border Grid.Row="2"
                Background="{Binding ContentBackground}"
                           
                Margin="0,0,0,0" Padding="20"
                 >

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- === Controls === -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="7"
                               Text="{Binding Label1Text}"
                               Foreground="DarkRed" FontStyle="Italic" FontSize="16"
                               Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="С какого магазина:" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="1" Grid.Column="1"
                              ItemsSource="{Binding StoreList}"
                              HorizontalAlignment="Left"
                              SelectedItem="{Binding SelectedStore}"
                              DisplayMemberPath="StoreCode"
                              FontSize="14"
                              IsEditable="True"
                              Width="150" Height="30" Margin="10,3,0,3"/>

                    <Button Grid.Row="1" Grid.Column="6"
                            Style="{StaticResource GreenButton}"
                            Content="Оформить"
                            Width="120" Height="35"
                            Command="{Binding SubmitCommand}"
                            IsEnabled="{Binding IsArtikulEnabled}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Артикул:" VerticalAlignment="Center" Margin="0,10,0,0"/>
                    <ComboBox x:Name="ArtikulComboBox"
                          Grid.Row="2" Grid.Column="1"
                          HorizontalAlignment="Left"
                          ItemsSource="{Binding ArtikulList}"
                          SelectedItem="{Binding SelectedArtikul, Mode=TwoWay}"
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          StaysOpenOnEdit="True"
                          DisplayMemberPath="ArticleNumber"
                          FontSize="14"
                          Width="260" Height="30" Margin="10,10,0,0"
                          IsEnabled="{Binding IsArtikulEnabled}">

                        <!-- ✅ Add this section -->
                        <ComboBox.InputBindings>
                            <KeyBinding Key="Enter"
                            Command="{Binding ConfirmSelectedArtikulCommand}" />
                        </ComboBox.InputBindings>
                    </ComboBox>


                    <TextBlock Grid.Row="2" Grid.Column="2"
                               Text="Количество" VerticalAlignment="Center" Margin="0,10,10,0"/>
                    <TextBox Grid.Row="2" Grid.Column="3" FontSize="14" VerticalContentAlignment="Center"
                             x:Name="QuantityTextBox"
                            Text="{Binding OrderQuantity, UpdateSourceTrigger=PropertyChanged}"
                             Width="100" Margin="0,10,0,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding ApplyQuantityCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                </Grid>

                <!-- === DataGrid === -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Products}"
                          Style="{StaticResource SummaryGrid}"  RowHeight="28"    IsReadOnly="False">
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <!-- ✅ Removes cell-level padding -->
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <!-- ✅ Ensures vertical center -->
                            <Setter Property="BorderThickness" Value="0"/>
                            <!-- optional: clean look -->
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Артикул" Binding="{Binding Artikul}" ElementStyle="{StaticResource CenterCellStyle}" Width="150"/>
                        <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" ElementStyle="{StaticResource CenterCellStyle}" Width="*"/>
                        <DataGridTextColumn Header="Бренд" Binding="{Binding Brand}" ElementStyle="{StaticResource CenterCellStyle}" Width="120"/>
                        <DataGridTextColumn Header="Марка" Binding="{Binding Marka}" ElementStyle="{StaticResource CenterCellStyle}" Width="120"/>
                        <DataGridTextColumn Header="Кол-во на складе" Binding="{Binding WarehouseQuantity}" ElementStyle="{StaticResource NumberCellStyle}" Width="140"/>
                        
                        <!-- ✅ Editable Quantity column with green background -->
                        <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="100" IsReadOnly="False" >
                            
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Background" Value="#41dc8e"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="10"/>
                                    <Setter Property="Margin" Value="0"/>

                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="#41dc8e"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                   
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Место" Binding="{Binding Location}" ElementStyle="{StaticResource CenterCellStyle}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
