<UserControl x:Class="PresentationWpf.Views.RetailView"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:local="clr-namespace:PresentationWpf.Views"
             xmlns:views="clr-namespace:PresentationWpf.Views"
             xmlns:viewmodels="clr-namespace:PresentationWpf.ViewModels"
              d:DataContext="{d:DesignInstance Type=viewmodels:RetailViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1000"
             FontSize="14">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Put in Window/Page/UserControl.Resources -->
        <Style x:Key="PriceEditorStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="#F3F3F3"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <!-- When IsBarter = true (on the DataGrid's DataContext), unlock the editor -->
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsBarter,
                                       RelativeSource={RelativeSource AncestorType=DataGrid}}"
                     Value="True">
                    <Setter Property="IsReadOnly" Value="False"/>
                    <Setter Property="Background" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>


        <!-- Rounded button with hover/pressed/focus states -->
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <!-- Base look -->
            <Setter Property="Background" Value="#566366"/>
            <!-- neutral dark -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#475154"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8"
                        Padding="8,6">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#627277"/>
                                <Setter Property="BorderBrush" Value="#516065"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4b5659"/>
                                <Setter Property="BorderBrush" Value="#40494b"/>
                            </Trigger>

                            <!-- Keyboard focus -->
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#FFFFFFFF"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#8C979A"/>
                                <Setter Property="Foreground" Value="#FFFFFFCC"/>
                                <Setter Property="BorderBrush" Value="#7B8689"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <!-- selected item area -->
            <Setter Property="HorizontalContentAlignment" Value="Left"/>

            <!-- dropdown items -->
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    </Style>
                </Setter.Value>
            </Setter>

            <!-- style the *inner* TextBox used when IsEditable=True -->
            <Style.Resources>
                <Style TargetType="TextBox">
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="TextAlignment" Value="Left"/>
                    <Setter Property="TextWrapping" Value="NoWrap"/>
                    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden"/>
                   
                </Style>
            </Style.Resources>
            
        </Style>
        
        
        <!-- Style for rounded TextBox -->
        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Background" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#566366"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Margin="5" 
                                          Padding="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for TextBlock (display mode) -->
        <Style x:Key="TextBlockPaddingStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="1,1"/>

        </Style>
        <!-- Style for DataGridCell with bottom border -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#336699"/>
            <Setter Property="Padding" Value="5,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>

            </Setter>
        </Style>

        <Style x:Key="CenteredTextBlockStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <!-- Style for DataGridCell with conditional coloring -->
        <Style x:Key="OrderQuentityCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="1,1,1,1"/>
            <Setter Property="BorderBrush" Value="#566366"/>
            <Setter Property="Padding" Value="5,5"/>
            <!--<Setter Property="Background" Value="#ededed"/>-->
            <Setter Property="HorizontalContentAlignment" Value="Center"/>

        </Style>

        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Define Rows and Columns -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid  Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel -->
            <Grid Grid.Column="0" Background="White" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- StackPanel info for order -->
                <StackPanel Background="#E0E5E6" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,10,0" Height="34">
                    <!-- Exchange Rate Display -->
                    <TextBlock Text="Продавец:" FontWeight="Bold" FontSize="11" Margin="0,2,10,10"/>
                    <TextBlock Text="{Binding User}" FontSize="14" Margin="0,0,20,10"/>

                    <!-- Exchange Rate Display -->
                    <TextBlock Text="Курс валюты:" FontWeight="Bold" FontSize="11" Margin="0,2,10,10"/>
                    <TextBlock Text="{Binding ExchangeRate}" FontSize="14" Margin="0,0,10,10"/>

                     <!-- Менеджер -->
                    <TextBlock Text="Менеджер:" FontWeight="Bold" FontSize="11" Margin="10,2,5,0" />
                    <ComboBox Width="200" Height="26"
                      ItemsSource="{Binding SalesManagerList}"
                      SelectedItem="{Binding SelectedSalesManager, Mode=TwoWay}"
                      DisplayMemberPath="DisplayText"
                      IsEditable="True"
                      TextSearch.TextPath="FullName"
                      Margin="0,2,10,0"/>

                    <!-- Маршрут -->
                    <TextBlock Text="Маршрут:" FontWeight="Bold" FontSize="11" Margin="10,2,5,0"/>
                    <ComboBox Width="150" Height="26"
                  ItemsSource="{Binding TerritoryOptions}"
                  SelectedValuePath="Value"
                  DisplayMemberPath="Display"
                  SelectedValue="{Binding SelectedTerritory, Mode=TwoWay}"
                  Margin="10,0,5,0">
                     
                    </ComboBox>
                    
                </StackPanel>

                <!-- Grid layout info for client -->
                <Grid Grid.Row="1" Background="#E0E5E6" Margin="10,5">
                    <!-- Define Columns -->
                    <Grid.ColumnDefinitions>
                        <!-- Код Клиента -->
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="10"/>

                        <!-- Доставщик -->
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="10"/>

                        <!-- Уровень -->
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="10"/>

                        <!-- Ограничение -->
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="10"/>

                        <!-- Необх.закуп -->
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="Auto"/>

                        <!-- Заплан.закуп -->
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Define Rows -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <!-- ========== ROW 0 ========== -->

                    <!-- Код Клиента -->
                    <TextBlock Text="Код Клиента" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Margin="2"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" Margin="2" 
              ItemsSource="{Binding CustomersView}"
              SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
              DisplayMemberPath="Id"
              IsEditable="True" TextSearch.TextPath="Id" FontSize="12"/>

                    <!-- Доставщик -->
                    <TextBlock Text="Доставщик" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center"  FontSize="12" Margin="2"/>
                    <ComboBox Grid.Row="0" Grid.Column="4" Margin="2"
              ItemsSource="{Binding CourierList}"
              SelectedItem="{Binding SelectedCourier, Mode=TwoWay}"
              DisplayMemberPath="FullName"
              IsEditable="True"
              IsTextSearchEnabled="True"
              TextSearch.TextPath="FullName"
              HorizontalContentAlignment="Left"
              FontSize="12"/>

                    <!-- Уровень -->
                    <TextBlock Text="Уровень" Grid.Row="0" Grid.Column="6" VerticalAlignment="Center"  FontSize="12" Margin="2"/>
                    <TextBox Grid.Row="0" IsReadOnly="True" Grid.Column="7" Text="{Binding SelectedCustomer.PriceLevelId}" FontSize="12" Margin="2"/>

                    <!-- Ограничение -->
                    <TextBlock Text="Ограничение" Grid.Row="0" Grid.Column="9" VerticalAlignment="Center" FontSize="12" Margin="2"/>
                    <TextBox Grid.Row="0" IsReadOnly="True" Grid.Column="10" Text="{Binding SelectedCustomer.Restriction}" FontSize="12" Margin="2" />

                    <!-- Необх.закуп -->
                    <TextBlock Text="Необх.закуп" Grid.Row="0" Grid.Column="12" VerticalAlignment="Center" FontSize="12" Margin="2"/>
                    <TextBox Grid.Row="0" Grid.Column="13" Padding="2" 
             Text="{Binding RequiredPurchase}" 
             Foreground="{Binding RequiredPurchaseColor}" 
             FontSize="12" Margin="2"/>

                    <ComboBox Grid.Row="1" Grid.Column="12" Grid.ColumnSpan="2" Margin="2"
              ItemsSource="{Binding InactiveDebtCustomers}"
              SelectedItem="{Binding SelectedRequiredPurchaseCombo}"
              FontSize="12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding FullName}" FontWeight="Bold"/>
                                    <TextBlock Text=" | "/>
                                    <TextBlock Text="Недоплата: " Foreground="Gray"/>
                                    <TextBlock Text="{Binding Shortfall}" Foreground="DarkRed"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        
                        
                    </ComboBox>

                    <TextBox Grid.Row="1" Grid.Column="14" VerticalContentAlignment="Center"
             Margin="2"
             Text="{Binding InactiveDebtCount, StringFormat=' (по долгу): {0}'}"
             FontSize="12" Foreground="DarkRed"/>

                    <!-- Заплан.закуп -->
                    <TextBlock Text="Заплан.закуп" Grid.Row="0" Grid.Column="16" VerticalAlignment="Center" FontSize="12" Margin="2"/>
                    <TextBox Grid.Row="0" Grid.Column="17" Padding="2" 
             Text="{Binding PlannedPurchase}" 
             Foreground="{Binding PlannedPurchaseColor}" 
             FontSize="12" Margin="2"/>

                    <ComboBox Grid.Row="1" Grid.Column="16" Grid.ColumnSpan="2" Margin="2"
              ItemsSource="{Binding InactivePlannedCustomers}"
              SelectedItem="{Binding SelectedPlannedPurchaseCombo}"
              FontSize="12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding FullName}" FontWeight="Bold"/>
                                    <TextBlock Text=" | "/>
                                    <TextBlock Text="Недозакуп: " Foreground="Gray"/>
                                    <TextBlock Text="{Binding Shortfall}" Foreground="DarkRed"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBox Grid.Row="1" Grid.Column="18" VerticalContentAlignment="Center"
             Text="{Binding InactivePlannedCount, StringFormat=' (по плану): {0}'}"
             FontSize="12" Margin="2" Foreground="DarkRed"/>

                    <!-- ========== ROW 1 ========== -->

                    <!-- ФИО -->
                    <TextBlock Text="ФИО" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"  FontSize="12" Margin="2"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" Margin="2" ItemsSource="{Binding CustomersView}"
              SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
              DisplayMemberPath="FullName"
              IsEditable="True" TextSearch.TextPath="FullName" FontSize="12"/>

                    <!-- Складщик -->
                    <TextBlock Text="Сборщик" Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" FontSize="12" Margin="2"/>
                    <ComboBox Grid.Row="1" Grid.Column="4" Margin="2" 
              ItemsSource="{Binding StorekeeperList}" 
              SelectedItem="{Binding SelectedStorekeeper, Mode=TwoWay}" 
              DisplayMemberPath="FullName"
              IsEditable="True" TextSearch.TextPath="FullName" FontSize="12"/>

                    <!-- Цена закупа -->
                    <TextBlock Text="Тел" Grid.Row="1" Grid.Column="6" VerticalAlignment="Center" FontSize="12" Margin="2"/>
                    <TextBox Grid.Row="1" IsReadOnly="True" Grid.Column="7" Margin="2" Text="{Binding SelectedCustomer.MobilePhone}" FontSize="12"/>

                    <!-- Заказ прямо со склада -->
                    <TextBlock Text="Заказ прямо со склада" Grid.Row="1" Grid.Column="9" VerticalAlignment="Center" FontSize="12" Margin="2"/>
                    <CheckBox Grid.Row="1" Grid.Column="10" Margin="3" IsChecked="{Binding IsDirectFromStock}" HorizontalAlignment="Left"/>
                </Grid>

                <!-- StackPanel create order -->
                <Grid Grid.Row="2" Background="#E0E5E6" Margin="10,0,10,5" Height="420">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>     <!-- header -->
                        <RowDefinition Height="*"/>         <!-- DataGrid (scrolls) -->
                        <RowDefinition Height="Auto"/>      <!-- total -->
                    </Grid.RowDefinitions>
                  
                    <!-- header -->
                    <Grid Grid.Row="0" Margin="10,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>      <!-- Просмотр Итогов -->
                            <ColumnDefinition Width="*"/>         <!-- Spacer -->
                            <ColumnDefinition Width="Auto"/>   <!-- Бартер -->
                            <ColumnDefinition Width="Auto"/>   <!-- Оформление бартера -->
                            <ColumnDefinition Width="Auto"/>   <!-- Оформить заказ -->
                        </Grid.ColumnDefinitions>

                        <!-- Итоги (moved left side) -->
                        <Button Grid.Column="0" Margin="0,0,0,0" 
                            Width="200" Height="40"
                            Command="{Binding ShowSummaryCommand}"
                            Style="{StaticResource OrangeButton}">
                            Итоги и платежи клиента
                        </Button>

                        <!-- Checkbox for Barter -->
                        <CheckBox Grid.Column="2" Content="Бартер" Margin="40,0"
                              
                              VerticalAlignment="Center"
                              IsChecked="{Binding IsBarter}"
                              ToolTip="Отметьте, если заказ оформляется по бартеру"/>
                      
                        <!-- Оформить заказ -->
                        <Button Grid.Column="4" Margin="10,0"
                            Width="150" Height="40"
                            FontWeight="Bold"
                            Command="{Binding SaveOrderCommand}"
                            Style="{StaticResource GreenButton}">
                            Оформить заказ
                        </Button>
                    </Grid>



                    <!--DataGrid (scrolls)-->
                    <DataGrid Grid.Row="1" CanUserAddRows="False" MaxHeight="600" GridLinesVisibility="None" Margin="10,0" FontSize="16" ItemsSource="{Binding SelectedProductList}" AutoGenerateColumns="False" IsReadOnly="False">
                        
                        <DataGrid.Columns>
                            <DataGridTextColumn MaxWidth="150" Header="Артикул" IsReadOnly="True" Binding="{Binding ArticleNumber}" ElementStyle="{StaticResource TextBlockPaddingStyle}" />
                            <DataGridTextColumn MaxWidth="350" Header="Наименование" IsReadOnly="True" Binding="{Binding ProductName}" ElementStyle="{StaticResource TextBlockPaddingStyle}"/>
                            <DataGridTextColumn MaxWidth="100" Header="Бренд" IsReadOnly="True" Binding="{Binding BrandName}" ElementStyle="{StaticResource TextBlockPaddingStyle}"/>
                            <DataGridTextColumn MaxWidth="150" Header="Марка" IsReadOnly="True" Binding="{Binding Marka}" ElementStyle="{StaticResource TextBlockPaddingStyle}"/>
                            <DataGridTextColumn MaxWidth="450" Width="*" Header="Модел" IsReadOnly="True" Binding="{Binding Model}" ElementStyle="{StaticResource TextBlockPaddingStyle}"/>
                            <DataGridTextColumn MaxWidth="70" Header="Кол-во" IsReadOnly="True" Binding="{Binding Quentity}" ElementStyle="{StaticResource TextBlockPaddingStyle}"/>
                            <!-- Customer price in EUR; blank until customer selected -->
                            <DataGridTemplateColumn MaxWidth="60" Header="Цена">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding EffectivePriceSom, StringFormat={}{0:0.##}}"
                                        VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>

                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding BarterPriceSom, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalContentAlignment="Center">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="IsReadOnly" Value="True"/>
                                                    <Setter Property="Background" Value="#F3F3F3"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Value="True"
                                                            Binding="{Binding DataContext.IsBarter,
                                                            RelativeSource={RelativeSource AncestorType=DataGrid}}">
                                                            <Setter Property="IsReadOnly" Value="False"/>
                                                            <Setter Property="Background" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            
                            <DataGridTextColumn
                                Header="Кол-во Заказа"
                                Binding="{Binding OrderQuentity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                ElementStyle="{StaticResource CenteredTextBlockStyle}"
                                CellStyle="{StaticResource OrderQuentityCellStyle}" />

                            <DataGridTextColumn  Width="90"
                                Header="Сумма"
                                IsReadOnly="True"
                                Binding="{Binding Total, StringFormat={}{0:F2}}"
                                ElementStyle="{StaticResource TextBlockPaddingStyle}" />

                            <!-- Delete Button Column -->
                            <DataGridTemplateColumn Header="Удалить">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Width="60" Height="35" Content="-" Background="#8B0000" Command="{Binding DataContext.RemoveProductCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Style="{StaticResource RoundedButtonStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>

                   

                    </DataGrid>
                    
                    <!-- total -->
                    <TextBlock  Grid.Row="2" HorizontalAlignment="Right" Margin="10" FontSize="16" FontWeight="Bold" Text="{Binding TotalSum, StringFormat='Итоговая Сумма (СМН): {0:F2}'}" />
                </Grid>


                <!-- Search Controls -->
                <Grid Grid.Row="3" Margin="5,5,5,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <CheckBox Content="Поиск всех кл.слов" VerticalAlignment="Center" VerticalContentAlignment="Center" FontSize="18" Foreground="#e67e22" Margin="10,0,0,0" Grid.Row="0" IsChecked="{Binding SearchAllWords}" />
                    <TextBox Style="{StaticResource RoundedTextBoxStyle}" Width="400" Height="50" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,7" Tag="Поиск" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />

                </Grid>

                <!-- DataGrid for Search Results -->
                <DataGrid Grid.Row="4" GridLinesVisibility="None" Height="448"
                          IsReadOnly="True"
                          Margin="10"
                          FontSize="16"
                          ItemsSource="{Binding ProductListView}"
                          SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          HorizontalScrollBarVisibility="Auto"
                          HorizontalContentAlignment="Stretch"
                          HorizontalAlignment="Stretch"
                          ColumnWidth="Auto">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Артикул" Binding="{Binding ArticleNumber}" ElementStyle="{StaticResource TextBlockPaddingStyle}"/>
                        <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" ElementStyle="{StaticResource TextBlockPaddingStyle}"/>
                        <DataGridTextColumn Header="Бренд" Binding="{Binding BrandName}" ElementStyle="{StaticResource TextBlockPaddingStyle}"/>
                        <DataGridTextColumn Header="Марка" Binding="{Binding Marka}" ElementStyle="{StaticResource TextBlockPaddingStyle}"/>
                        <DataGridTextColumn MaxWidth="450" Header="Модел"  Width="*" Binding="{Binding Model}" ElementStyle="{StaticResource TextBlockPaddingStyle}"/>
                        <DataGridTextColumn Header="Кол-во" Binding="{Binding Quentity}" ElementStyle="{StaticResource TextBlockPaddingStyle}"/>
                        <DataGridTextColumn Header="Розн(CМН)"
                        Binding="{Binding RetailPrice, Mode=OneWay, StringFormat={}{0:N2}}"
                        IsReadOnly="True" />
                        <!-- Customer price in EUR; blank until customer selected -->
                        <DataGridTextColumn Header="Цена(€)"
                        Binding="{Binding CustomerPrice,
                        Mode=OneWay,
                        StringFormat={}{0:N2},
                        TargetNullValue=''}"
                        IsReadOnly="True" />
                        <!-- Add Button Column -->
                        <DataGridTemplateColumn Header="Добавить">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="+" Width="60" Height="35" Command="{Binding DataContext.AddToChartCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Style="{StaticResource RoundedButtonStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Right Panel -->
            <StackPanel Orientation="Vertical" Grid.Column="1" Background="#5C656E" >
                <Button Width="250" Height="35" Margin="0,10,0,5"
                    Command="{Binding ShowPendingOrdersCommand}"
                    Style="{StaticResource GrayButton}">
                    Заказы в ожидании отправки
                </Button>

                <Button Width="250" Height="35" Margin="0,0,0,5"
                    Command="{Binding ShowDeliveryOrdersCommand}"
                    Style="{StaticResource GrayButton}">
                    Доставка заказов
                </Button>

                <Button Width="250" Height="35" Margin="0,0,0,25"
                    Command="{Binding ShowAssignPickersCommand}"
                    Style="{StaticResource GrayButton}">
                    Назначение комплектовщиков
                </Button>


                <Label Grid.Column="0" VerticalAlignment="Center" VerticalContentAlignment="Center" FontSize="18" Foreground="#e67e22" >Альтернативы товара</Label>
                <DataGrid GridLinesVisibility="None" IsReadOnly="True" Margin="5" FontSize="12" ItemsSource="{Binding AlternativeProductList}" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Бренд" Width="65" Binding="{Binding BrandName}" ElementStyle="{StaticResource TextBlockPaddingStyle}"/>
                        <DataGridTextColumn Header="Кол" Width="35" Binding="{Binding Quentity}" ElementStyle="{StaticResource TextBlockPaddingStyle}" />
                        <DataGridTextColumn Header="СМН" Width="60" Binding="{Binding RetailPrice, StringFormat=\{0:F2\}}" ElementStyle="{StaticResource TextBlockPaddingStyle}"/>
                        <DataGridTextColumn Header="€" Width="50" Binding="{Binding CustomerPrice, StringFormat=\{0:F2\}}" ElementStyle="{StaticResource TextBlockPaddingStyle}"/>
                        <!-- Add Button Column -->
                        <DataGridTemplateColumn Header="Добавить">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="+" Width="60" Height="35"  Command="{Binding DataContext.AddToChartCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Style="{StaticResource RoundedButtonStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Grid>

        
    </Grid>

</UserControl>
