<UserControl x:Class="PresentationWpf.Views.WarehousePlaceReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PresentationWpf.Views"
             xmlns:sys="clr-namespace:System;assembly=mscorlib" xmlns:local1="clr-namespace:PresentationWpf.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <local1:NullToAllConverter x:Key="NullToAllConverter"/>
    </UserControl.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <!--<RowDefinition Height="Auto"/>-->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <!--<StackPanel>
            <TextBlock Text="ОТЧЁТ О МЕСТЕ НА СКЛАДЕ"
                       FontSize="22"
                       FontWeight="Bold"/>

            <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat={}{0:dd.MM.yyyy}}"
                       Foreground="Gray"/>
        </StackPanel>-->

        <!-- FILTERS -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,15,0,15"
                    VerticalAlignment="Center">

            <TextBlock Text="Сектор:" VerticalAlignment="Center" Margin="0,0,5,0"/>

            <ComboBox Width="80"
                      FontSize="14"
                      Height="30"
                      IsEditable="True"
                      IsTextSearchEnabled="True"
                      ItemsSource="{Binding Sections}"
                      DisplayMemberPath="Display"
                      SelectedValuePath="Value"
                      SelectedValue="{Binding SelectedSection, Mode=TwoWay}"/>

            <TextBlock Text="Ряд:" VerticalAlignment="Center" Margin="10,0,5,0"/>

            <ComboBox Width="80"
                      FontSize="14"
                      Height="30"
                      IsEditable="True"
                      IsTextSearchEnabled="True"
                      ItemsSource="{Binding Rows}"
                      DisplayMemberPath="Display"
                      SelectedValuePath="Value"
                      SelectedValue="{Binding SelectedRow, Mode=TwoWay}"/>

            <TextBlock Text="Место:" VerticalAlignment="Center" Margin="10,0,5,0"/>

            <ComboBox Width="80"
                      FontSize="14"
                      Height="30"
                      IsEditable="True"
                      IsTextSearchEnabled="True"
                      ItemsSource="{Binding Places}"
                      DisplayMemberPath="Display"
                      SelectedValuePath="Value"
                      SelectedValue="{Binding SelectedPlace, Mode=TwoWay}"/>

            <CheckBox Content="Вкл. нулевое количество" VerticalAlignment="Center"
                      IsChecked="{Binding IncludeZeroQuantity}"
                      Margin="15,0"/>

            <Button Content="Печать"
                    Style="{StaticResource GrayButton}"
                    Command="{Binding PrintCommand}"
                    Margin="20,0,0,0"
                    MinWidth="70"/>

            <Button Content="Excel"
                    Style="{StaticResource GrayButton}"
                    Command="{Binding ExportExcelCommand}"
                    CommandParameter="{Binding ElementName=GridReport}"
                    Margin="10,0,0,0"
                    MinWidth="70"/>
        </StackPanel>

        <!-- TABLE -->
        <DataGrid x:Name="GridReport"
                  Style="{StaticResource SummaryGrid}"
                  Grid.Row="1"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Место"
                                    Binding="{Binding PlaceCode}"
                                    Width="100"/>

                <DataGridTextColumn Header="Артикул"
                                    Binding="{Binding Article}"
                                    Width="120"/>

                <DataGridTextColumn Header="Наименование"
                                    Binding="{Binding Name}"
                                    Width="*"/>

                <DataGridTextColumn Header="Бренд"
                                    Binding="{Binding Brand}"
                                    Width="120"/>

                <DataGridTextColumn Header="Марка"
                                    Binding="{Binding Mark}"
                                    Width="120"/>

                <DataGridTextColumn Header="Модель"
                                    Binding="{Binding Model}"
                                    Width="200"/>

                <DataGridTextColumn Header="Кол-во"
                                    Binding="{Binding Quantity}"
                                    Width="80"/>

                <DataGridTextColumn Header="Исп"
                                        Width="60"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>

</UserControl>
