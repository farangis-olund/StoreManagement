<UserControl x:Class="PresentationWpf.Views.SalesManagerReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PresentationWpf.Views"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <!-- ===================== -->
        <!-- FILTER PANEL -->
        <!-- ===================== -->
        <StackPanel Orientation="Horizontal"
                Margin="0,0,0,10"
                VerticalAlignment="Center">

            <TextBlock Text="С:" Margin="0,0,5,0" VerticalAlignment="Center"/>
            <DatePicker SelectedDate="{Binding DateFrom}"
                    Width="140"
                    Height="30"
                    FontSize="13"
                    Margin="0,0,15,0"/>

            <TextBlock Text="По:" Margin="0,0,5,0" VerticalAlignment="Center"/>
            <DatePicker SelectedDate="{Binding DateTo}"
                    Width="140"
                    Height="30"
                    FontSize="13"
                    Margin="0,0,20,0"/>

            <TextBlock Text="Менеджер:" Margin="0,0,5,0" VerticalAlignment="Center"/>
            <ComboBox Width="160"
                   IsEditable="True"
                    IsTextSearchEnabled="True"
                  ItemsSource="{Binding Managers}"
                  SelectedItem="{Binding SelectedManager}"
                  Margin="0,0,15,0"
                  Height="30"
                  FontSize="13"/>

            <TextBlock Text="Фирма:" Margin="0,0,5,0" VerticalAlignment="Center"/>
            <ComboBox Width="160"
                       IsEditable="True"
                    IsTextSearchEnabled="True"
                  ItemsSource="{Binding Firmas}"
                  SelectedItem="{Binding SelectedFirma}"
                  Height="30"
                  FontSize="13"/>

        </StackPanel>

        <!-- ===================== -->
        <!-- TABLE -->
        <!-- ===================== -->
        <DataGrid x:Name="ReportGrid"
              Grid.Row="2"
              ItemsSource="{Binding PivotRows}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              Style="{StaticResource SummaryGrid}"
              ColumnHeaderHeight="50"
              Margin="0,5,0,10"/>

      
        <!-- CHART -->
        <lvc:CartesianChart Grid.Row="3"
                        Series="{Binding SeriesCollection}"
                        LegendLocation="Right">

            <lvc:CartesianChart.AxisX>
                <lvc:Axis Labels="{Binding Labels}" 
                      LabelsRotation="60" Foreground="#222">
                    <lvc:Axis.Separator>
                        <lvc:Separator Step="1"/>
                    </lvc:Axis.Separator>
                </lvc:Axis>
            </lvc:CartesianChart.AxisX>

            
            
           <lvc:CartesianChart.AxisY>
                <lvc:Axis Title="Итоги продажи" FontSize="14"
                      Foreground="#222" 
                      LabelFormatter="{Binding Formatter}">
                    <lvc:Axis.Separator>
                        <lvc:Separator Stroke="#E0E0E0"
                                   StrokeThickness="1"/>
                    </lvc:Axis.Separator>
                    
                </lvc:Axis>
               
            </lvc:CartesianChart.AxisY>

        </lvc:CartesianChart>

    </Grid>
</UserControl>
