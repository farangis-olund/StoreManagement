<UserControl x:Class="PresentationWpf.Views.SalesSummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
               xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:local="clr-namespace:PresentationWpf.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TITLE ================= -->
        <TextBlock Text="ИТОГИ ПО ПРОДАЖАМ"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6"/>

        <!-- separator -->
        <Border Grid.Row="1"
                Height="1"
                Background="#3A6EA5"
                Margin="0,0,0,10"/>

       
        <!-- ================= GRID + FOOTER ================= -->
        <Grid Grid.Row="3">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Grid Grid.Column="0">

                <Grid.RowDefinitions>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

                <!-- ================= FILTER + ACTIONS ================= -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>


                    </Grid.ColumnDefinitions>

                    <!-- Filters -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Клиент"
                    VerticalAlignment="Center"
                    Margin="0,0,6,0"/>

                        <ComboBox Width="130"
                   Height="30"
                   
                   ItemsSource="{Binding Clients}"
                   SelectedItem="{Binding SelectedClient, Mode=TwoWay}"
                     DisplayMemberPath="DisplayText"
                     VerticalAlignment="Center"
                     FontSize="14"
                     IsEditable="True"
                     IsTextSearchEnabled="True"
                     StaysOpenOnEdit="True"
                     TextSearch.TextPath="DisplayText"/>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Grid.Column="2"
                         Orientation="Horizontal"
                         Margin="20,0,0,0">

                        <Button Content="Показать все"
                             Width="100"
                             Style="{StaticResource GrayButton}"
                             Command="{Binding ShowAllCommand}"/>

                        <Button Margin="6,0,0,0" Style="{StaticResource GrayButton}"
                          Command="{Binding PrintCommand}"
                          Width="100"
                          Height="32">
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="Print" Width="16" Height="16" Margin="0,0,6,0"/>
                                <TextBlock Text="Печать"/>
                            </StackPanel>
                        </Button>

                        <Button Content="Акт сверки"
                              Style="{StaticResource GrayButton}"
                              Width="100"
                              Command="{Binding ActSverkiCommand}"
                             Margin="6,0,0,0"/>

                        <Button Margin="6,0,0,0" Style="{StaticResource GrayButton}"
                               Command="{Binding PrintDetailInfoCommand}"
                               Width="50"
                               Height="32">
                            <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="InfoCircle" Width="16" Height="16"/>
                                
                            </StackPanel>
                        </Button>

                    </StackPanel>

                </Grid>

                <!-- ================= GRID ================= -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Sales}"
                          Style="{StaticResource SummaryGrid}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          RowHeight="26"
                          FontSize="13">

                    <!-- Header -->
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Background" Value="#F2F2F2"/>
                            <Setter Property="BorderBrush" Value="#D0D0D0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="Padding" Value="6,4"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <!-- Cells -->
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="6,2"/>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Код"
                                            Binding="{Binding ClientCode}"
                                            Width="70"/>

                        <DataGridTextColumn Header="ФИО"
                                            Binding="{Binding ClientName}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Адрес"
                                            Binding="{Binding Address}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Телефон"
                                            Binding="{Binding Phone}"
                                            Width="100"/>

                        <DataGridTextColumn Header="Дата"
                                            Binding="{Binding MaxDate, StringFormat=d}"
                                            Width="90"/>

                        <DataGridTextColumn Header="Остаток"
                                            Binding="{Binding Balance, StringFormat=N2}"
                                            Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                    </DataGrid.Columns>
                </DataGrid>
        
                <!-- FOOTER (STUCK TOTAL) -->
                <Border Grid.Row="2"
                Background="#F5F5F5"
                BorderBrush="#D0D0D0"
                BorderThickness="0,1,0,0"
                Padding="6">

                <!-- Column-aligned layout -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <!-- Label -->
                    <TextBlock Grid.Column="0"
                           Grid.ColumnSpan="5"
                           Text="ИТОГО"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                    <!-- Total amount -->
                    <TextBlock Grid.Column="5"
                           Text="{Binding TotalAmount, StringFormat=N2}"
                           FontWeight="Bold"
                           FontSize="14"
                           TextAlignment="Right"
                           VerticalAlignment="Center"/>
                </Grid>
            </Border>
            </Grid>
            
            <Border Grid.Column="1"
                Width="1"
                Background="#D0D0D0"
                Margin="4,0"/>

            <!-- ================= RIGHT: INACTIVE CLIENTS ================= -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Period + buttons -->
                    <RowDefinition Height="Auto"/>
                    <!-- Manager + filter -->
                    <RowDefinition Height="Auto"/>
                    <!-- Title -->
                    <RowDefinition Height="*"/>
                    <!-- DataGrid -->
                </Grid.RowDefinitions>

                <!-- ================= PERIOD + BUTTONS ================= -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- ЛЕВАЯ ЧАСТЬ (период) -->
                    <StackPanel Orientation="Vertical"
                        VerticalAlignment="Center"
                        Margin="0,0,0,10">

                        <!-- PERIOD ROW -->
                        <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">

                            <TextBlock Text="Период:" Margin="0,0,6,0"/>

                            <DatePicker Width="100"
                                Height="30"
                                SelectedDate="{Binding PeriodFrom, Mode=TwoWay}"
                                Margin="0,0,6,0"
                                IsEnabled="{Binding UsePeriod}"/>

                            <TextBlock Text="по" Margin="0,0,6,0"/>

                            <DatePicker Width="100"
                                Height="30"
                                SelectedDate="{Binding PeriodTo, Mode=TwoWay}"
                                IsEnabled="{Binding UsePeriod}"/>
                        </StackPanel>

                        <!-- CHECKBOX BELOW -->
                        <CheckBox Content="Использовать период"
                          IsChecked="{Binding UsePeriod}"
                          Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- ПРАВАЯ КНОПКА -->
                    <Button Grid.Column="1" Margin="0,0,6,0"
                        VerticalAlignment="Top"
                        Content="Задолженность без оборота"
                        Style="{StaticResource GrayButton}"
                        Width="200"
                        Command="{Binding InactiveReportCommand}"/>

                    <Button Grid.Column="2" Style="{StaticResource GrayButton}"
                         Command="{Binding PrintAllInactivesCommand}"
                            VerticalAlignment="Top"
                         Width="100"
                         Height="32">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Print" Width="16" Height="16" Margin="0,0,6,0"/>
                            <TextBlock Text="Печать"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- ================= MANAGER + FILTER ================= -->
                <Grid Grid.Row="1" Margin="0,10,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>            <!-- Manager block -->
                        <ColumnDefinition Width="*"/>                <!-- Spacer -->
                        <ColumnDefinition Width="Auto"/>             <!-- Buttons -->
                    </Grid.ColumnDefinitions>

                    <!-- MANAGER BLOCK -->
                    <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                                    <TextBlock Text="Менеджер"
                           VerticalAlignment="Center"
                           Margin="0,0,5,0"
                           FontSize="14"
                           FontWeight="SemiBold"/>

                          <ComboBox Width="200"
                           Margin="0,0,6,0"
                          Height="30"
                          ItemsSource="{Binding Managers}"
                          SelectedItem="{Binding SelectedManager, Mode=TwoWay}"
                          DisplayMemberPath="FullName"
                          FontSize="14"
                          IsEditable="True"
                          IsTextSearchEnabled="True"
                          StaysOpenOnEdit="True"
                          TextSearch.TextPath="FullName"/>

                    </StackPanel>
                    <!-- BUTTONS BLOCK -->
                    <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">

                        <Button Width="200"
                            Height="30"
                            Margin="0,0,6,0"
                            Content="Неактивные клиенты"
                            Style="{StaticResource GrayButton}"
                            Command="{Binding LoadClientsByManagerCommand}"/>

                            <Button Style="{StaticResource GrayButton}"
                                 Command="{Binding PrintInactivesCommand}"
                                 Width="100"
                                 Height="32">
                                <StackPanel Orientation="Horizontal">
                                <fa:ImageAwesome Icon="Print" Width="16" Height="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="Печать"/>
                            </StackPanel>
                            </Button>

                    </StackPanel>
                </Grid>


                <!-- ================= TITLE ================= -->
                <TextBlock Grid.Row="2"
               Text="Список не активных клиентов"
               FontWeight="SemiBold"
               Margin="0,0,0,6"/>

                <!-- ================= DATAGRID ================= -->
                <DataGrid Grid.Row="3"
              ItemsSource="{Binding InactiveClients}"
              Style="{StaticResource SummaryGrid}"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              HeadersVisibility="Column"
              RowHeight="26"
              FontSize="13">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Код"
                                Binding="{Binding ClientCode}"
                                Width="80"/>

                        <DataGridTextColumn Header="ФИО"
                                Binding="{Binding ClientName}"
                                Width="*"/>

                        <DataGridTextColumn Header="Тел"
                                Binding="{Binding Phone}"
                                Width="130"/>

                        <DataGridTextColumn Header="Адрес"
                                Binding="{Binding Address}"
                                Width="*"/>

                        <DataGridTextColumn Header="Дата"
                                Binding="{Binding MaxDate, StringFormat=d}"
                                Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>


        </Grid>
    </Grid>

</UserControl>
