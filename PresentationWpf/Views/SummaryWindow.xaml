<UserControl x:Class="PresentationWpf.Views.SummaryWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PresentationWpf.Views"
             xmlns:views="clr-namespace:PresentationWpf.Views"
             
             xmlns:viewmodels="clr-namespace:PresentationWpf.ViewModels" 
             d:DataContext="{d:DesignInstance Type=viewmodels:SummaryViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="1000">

    <UserControl.Resources>

        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <!-- Remove cell border -->
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="4,0,4,0"/>

            <Style.Triggers>
                <!-- Highlight entire row only when selected -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3399FF"/>
                    <!-- Blue row highlight -->
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- optional cell text styles -->
        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="CellTextRight" TargetType="TextBlock" BasedOn="{StaticResource CellText}">
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>
        <Style x:Key="CellTextCenter" TargetType="TextBlock" BasedOn="{StaticResource CellText}">
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
      

    </UserControl.Resources>


    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Totals row -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Продажа: " FontWeight="Bold" Foreground="#e67e22" VerticalAlignment="Center"/>
                <TextBox Width="120" IsReadOnly="True" Margin="4,0,20,0" VerticalContentAlignment="Center"
                         Text="{Binding TotalSales, Mode=OneWay, StringFormat={}{0:N2}}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Оплата: " FontWeight="Bold" Foreground="#27ae60" VerticalAlignment="Center"/>
                <TextBox Width="120" IsReadOnly="True" Margin="4,0,20,0" VerticalContentAlignment="Center"
                         Text="{Binding TotalPayments, Mode=OneWay, StringFormat={}{0:N2}}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Остаток: " FontWeight="Bold" Foreground="#c0392b" VerticalAlignment="Center"/>
                <TextBox Width="120" Height="25" IsReadOnly="True" Margin="4,0,0,0" VerticalContentAlignment="Center"
                         Text="{Binding Balance, Mode=OneWay, StringFormat={}{0:N2}}"/>
            </StackPanel>
        </StackPanel>

        <!-- Orders and Payments grids -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Orders -->
            <GroupBox Header="Заказы" Grid.Column="0">
                <DockPanel Margin="0,4,0,0">
                    <!-- Buttons -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Content="Просмотр накладной" Padding="8,6"
                            Command="{Binding ViewInvoiceCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedOrder}" Value="{x:Null}">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Orders grid -->
                    <DataGrid ItemsSource="{Binding Orders}"
                              SelectedItem="{Binding SelectedOrder, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              Style="{StaticResource SummaryGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="90"
                                  Header="Дата"
                                  Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- № Платежа -->
                            <DataGridTextColumn Width="*"
                                      Header="№ Накладной"
                                      Binding="{Binding InvoiceNo}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CellText}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Сумма -->
                            <DataGridTextColumn Width="100"
                                  Header="Сумма"
                                  Binding="{Binding Amount, StringFormat={}{0:N2}}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CellTextCenter}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>

            <!-- Payments panel (new payment + list) -->
            <StackPanel Grid.Column="2">
                <!-- New Payment -->
                <GroupBox Header="Новый платеж" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" Margin="8" VerticalAlignment="Center">
                        <TextBlock Text="Сумма" VerticalAlignment="Center"/>
                        <TextBox Width="100" Margin="6,0,12,0" VerticalContentAlignment="Center" Padding="5"
                                 Text="{Binding PaymentAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Оформить платеж" Style="{StaticResource GreenButton}"
                                Padding="10,6"
                                Width="140"
                                Command="{Binding AddPaymentCommand}" />
                    </StackPanel>
                </GroupBox>

                <!-- Payments -->
                <GroupBox Header="Платежи">
                    <DockPanel Margin="0,4,0,0">
                        <!-- Buttons -->
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="Просмотр квитанции" Padding="8,6" Width="140"
                            Command="{Binding ViewPaymentCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="IsEnabled" Value="True"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPayment}" Value="{x:Null}">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                        </StackPanel>

                        <!-- Payments grid -->
                        <DataGrid ItemsSource="{Binding Payments}"
                                  SelectedItem="{Binding SelectedPayment, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  Style="{StaticResource SummaryGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="100"
                                Header="Дата"
                                Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CellText}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- № Платежа -->
                                <DataGridTextColumn Width="110"
                                Header="№ Квитанции"
                                Binding="{Binding PaymentNo}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CellTextCenter}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <!-- Сумма -->
                                <DataGridTextColumn Width="*"
                                Header="Сумма"
                                Binding="{Binding Amount, StringFormat={}{0:N2}}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CellTextCenter}"/>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                          
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </GroupBox>
            </StackPanel>

            <!-- Orders -->
            <GroupBox Header="Неоплаченные платежи" Grid.Column="4">
                <DockPanel Margin="0,4,0,0">
                  
                    <!-- Orders grid -->
                    <DataGrid ItemsSource="{Binding UnpaidOrders}"
                   SelectedItem="{Binding UnpaidOrder, Mode=TwoWay}"
                   AutoGenerateColumns="False"
                   CanUserAddRows="False"
                   IsReadOnly="True"
                   HeadersVisibility="Column"
                   Style="{StaticResource SummaryGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Width="90"
                       Header="Дата"
                       Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CellTextCenter}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- № Платежа -->
                            <DataGridTextColumn Width="115"
                           Header="№ Квитанции"
                           Binding="{Binding PaymentId}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CellTextCenter}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Сумма -->
                            <DataGridTextColumn Width="*"
                       Header="Сумма платежа"
                       Binding="{Binding Paid, StringFormat={}{0:N2}}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CellTextCenter}"/>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>

        </Grid>
    </Grid>
</UserControl>
