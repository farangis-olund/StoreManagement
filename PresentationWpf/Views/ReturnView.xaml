<UserControl x:Class="PresentationWpf.Views.ReturnView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PresentationWpf.Views"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="1000"  
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:ei="http://schemas.microsoft.com/expression/2010/interactions">

            <i:Interaction.Triggers>
                <i:EventTrigger EventName="Loaded">
                    <i:InvokeCommandAction Command="{Binding LoadedCommand}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>


    <!-- ROOT GRID -->
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- search strip -->
                <RowDefinition Height="Auto"/>
                <!-- results expander -->
                <RowDefinition Height="*"/>
                <!-- main content -->
            </Grid.RowDefinitions>

            <!-- ───── Search strip ───────────────────────────────────────── -->
        <Border Margin="0,0,0,8" Padding="10" BorderBrush="#E0E3E7" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <!-- One-box keywords -->
                <TextBox Grid.Column="0" Height="40" Margin="0,0,10,0"  Style="{StaticResource RoundedTextBoxStyle}"
                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
             ToolTip="Введите несколько ключевых слов: артикул, имя клиента, модель, бренд, № накладной"/>

                <DatePicker Grid.Column="1" Height="30" Margin="0,0,10,0"
                SelectedDate="{Binding SearchFrom, UpdateSourceTrigger=PropertyChanged}"/>

                <DatePicker Grid.Column="2" Height="30"
                SelectedDate="{Binding SearchTo, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
            
        </Border>

        <!-- ───── Collapsible search results (line level) ────────────── -->
        <GroupBox Header="Результаты поиска" Grid.Row="1" Margin="0,0,0,8">
            <Expander IsExpanded="{Binding SearchExpanded}">
                <DataGrid ItemsSource="{Binding SearchResultsView}"
                  SelectedItem="{Binding SelectedSearchHit, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  ScrollViewer.CanContentScroll="True"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.ScrollUnit="Pixel"
                  HorizontalScrollBarVisibility="Auto"
                  HorizontalContentAlignment="Stretch"
                  HorizontalAlignment="Stretch"
                  Style="{StaticResource SummaryGrid}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}" Width="80"/>
                        <DataGridTextColumn Header="Накладная" Binding="{Binding OrderId}" Width="90"/>
                        <DataGridTextColumn Header="Клиент" Binding="{Binding CustomerName}" Width="160"/>
                        <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="110"/>
                        <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="160"/>
                        <DataGridTextColumn Header="Бренд" Binding="{Binding Brand}" Width="110"/>
                        <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="140"/>
                        <DataGridTextColumn Header="Кол" Binding="{Binding Quantity}" Width="50"/>
                        <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:N2}}" Width="80"/>
                        <DataGridTemplateColumn Header="Выбрать" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="+" FontSize="10" 
                                    Style="{StaticResource OrangeButton}" 
                                    Width="50" Height="25"
                                    Command="{Binding DataContext.UseSearchHitCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Expander>
        </GroupBox>

        <!-- ───── Main content ───────────────────────────────────────── -->
            <Grid Grid.Row="2" Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>


            <GroupBox Header="Ручное оформление (без накладной)" Margin="0,0,0,8">
                <GroupBox.Style>
                    <Style TargetType="GroupBox">
                        <!-- Default look -->
                        <Setter Property="BorderBrush" Value="#CCC"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Style.Triggers>
                            <!-- When ManualMode ON -->
                            <DataTrigger Binding="{Binding ManualMode}" Value="True">
                                <Setter Property="BorderBrush" Value="Green"/>
                                <Setter Property="Foreground" Value="Green"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GroupBox.Style>

                <!-- Содержимое оборачиваем в Expander -->
                <Expander IsExpanded="{Binding ManualMode}">
                    <Expander.Header>
                        <DockPanel>
                            <TextBlock Text="Если накладная не найдена — оформите вручную"
                           Foreground="#888" FontSize="12"
                           VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                <TextBlock Text="Включить" Margin="12,0,8,0"
                               VerticalAlignment="Center"/>
                                <CheckBox IsChecked="{Binding ManualMode}"/>
                            </StackPanel>
                        </DockPanel>
                    </Expander.Header>

                    <!-- Весь твой старый Grid -->
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Customer / Product pickers -->
                        <Grid Grid.Row="2" IsEnabled="{Binding ManualMode}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Клиент (код/ФИО)" Margin="0,0,0,4"/>
                                <ComboBox Height="30"
                              ItemsSource="{Binding CustomersFiltered}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="FullName"
                              SelectedValue="{Binding ManualCustomerId}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Товар (артикул)" Margin="0,0,0,4"/>
                                <ComboBox Height="30" Width="200"
                              ItemsSource="{Binding ProductsLookup}"
                              SelectedItem="{Binding SelectedManualProduct, Mode=TwoWay}"
                              SelectedValuePath="Article"
                              DisplayMemberPath="Display"
                              SelectedValue="{Binding ManualArticle}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Qty / Price + Add button -->
                        <Grid Grid.Row="4" IsEnabled="{Binding ManualMode}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Vertical">
                                <TextBlock Text="Кол-во" Margin="0,0,0,4"/>
                                <TextBox Width="90" Height="30" HorizontalContentAlignment="Right"
                             Text="{Binding ManualQty, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Vertical">
                                <TextBlock Text="Цена" Margin="0,0,0,4"/>
                                <TextBox Width="110" Height="30" HorizontalContentAlignment="Right"
                             Text="{Binding ManualPrice, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <DockPanel Grid.Column="4" LastChildFill="False">
                                <Button Content="Добавить позицию" Width="170" Height="30"
                            Command="{Binding AddManualLineCommand}"
                            IsEnabled="{Binding ManualMode}"
                            Style="{StaticResource OrangeButton}"/>
                            </DockPanel>
                        </Grid>
                    </Grid>
                </Expander>
            </GroupBox>

            <!-- Body -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Lines grid -->
                    <GroupBox Header="Позиции возврата" Grid.Column="0">
                        <DockPanel>
                         
                        <DataGrid ItemsSource="{Binding Lines}"
                      AutoGenerateColumns="False"
                      SelectionMode="Extended"
                      IsReadOnly="False"
                      Style="{StaticResource SummaryGrid}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="120"/>
                                    <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Бренд" Binding="{Binding Brand}" Width="100"/>
                                    <DataGridTextColumn Header="Марка" Binding="{Binding Marka}" Width="100"/>
                                    <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="100"/>
                                    <DataGridTextColumn Header="Куплено"   Binding="{Binding PurchasedQty}"  Width="70" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="К возврату" Binding="{Binding ReturnQty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                    <DataGridTextColumn Header="Цена" Binding="{Binding Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N2}}" Width="80"/>
                                    <DataGridTextColumn Header="Сумма" Binding="{Binding Total, StringFormat={}{0:N2}}" Width="90" IsReadOnly="True"/>
                                    <DataGridTemplateColumn Header="">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                            <Button Content="-" Background="#8B0000" Width="50" Height="24" FontSize="10" Style="{StaticResource RoundedButtonStyle}" 
                                                  Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </GroupBox>

                    <!-- Right panel -->
                    <StackPanel Grid.Column="2">
                        <GroupBox Header="Оформление">
                            <StackPanel Margin="8">
                                <TextBlock Text="Причина"/>
                                <TextBox Text="{Binding Reason}"/>

                                <TextBlock Text="Способ возврата средств" Margin="0,6,0,0"/>
                                <ComboBox SelectedValue="{Binding RefundMethod}">
                                    <ComboBoxItem Content="Наличные" Tag="cash"/>
                                    <ComboBoxItem Content="Зачесть в баланс" Tag="credit"/>
                                    <ComboBoxItem Content="Перевод" Tag="transfer"/>
                                </ComboBox>

                                <TextBlock Text="Комментарий" Margin="0,6,0,0"/>
                                <TextBox Text="{Binding Comment}" AcceptsReturn="True" Height="80"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Итоги" Margin="0,8,0,0">
                            <StackPanel Margin="8">
                                <DockPanel>
                                    <TextBlock Text="Сумма:" DockPanel.Dock="Left"/>
                                    <TextBlock Text="{Binding Subtotal, StringFormat={}{0:N2}}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Text="К возврату:" DockPanel.Dock="Left"/>
                                    <TextBlock Text="{Binding RefundAmount, StringFormat={}{0:N2}}" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </DockPanel>
                            </StackPanel>
                        
                        </GroupBox>

                    <DockPanel Margin="0,12,0,0">
                        <Button Content="Оформить возврат"
                           
                            Height="34" Width="140" HorizontalAlignment="Right"
                            Command="{Binding SubmitAsyncCommand}"
                            Style="{StaticResource GreenButton}"/>
                    </DockPanel>
                </StackPanel>
                </Grid>
            
             </Grid>
        </Grid>
    </UserControl>


