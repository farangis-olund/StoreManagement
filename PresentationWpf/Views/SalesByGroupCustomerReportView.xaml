<UserControl x:Class="PresentationWpf.Views.SalesByGroupCustomerReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PresentationWpf.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FILTER PANEL -->
        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,10"
                    VerticalAlignment="Center">

            <TextBlock Text="С:"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>

            <DatePicker SelectedDate="{Binding FromDate}"
                        Width="130"
                        Height="30"
                        FontSize="13"
                        Margin="0,0,15,0"/>

            <TextBlock Text="По:"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>

            <DatePicker SelectedDate="{Binding ToDate}"
                        Width="130"
                        Height="30"
                        FontSize="13"
                        Margin="0,0,20,0"/>

            <TextBlock Text="Фирма:"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>

            <ComboBox Width="160"
                      Height="30"
                       IsEditable="True"
                    IsTextSearchEnabled="True"
                        FontSize="13"
                      ItemsSource="{Binding Firmas}"
                      SelectedItem="{Binding SelectedFirma}"
                      Margin="0,0,15,0"/>

            <TextBlock Text="Регион:"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>

            <ComboBox Width="160"
                      Height="30"
                      FontSize="13"
                       IsEditable="True"
                        IsTextSearchEnabled="True"
                      ItemsSource="{Binding Regions}"
                      SelectedItem="{Binding SelectedRegion}"/>

            <CheckBox Content="Итоги по количеству"
              Margin="20,0,0,0"
              VerticalAlignment="Center"
              IsChecked="{Binding TotalsByQuantity}"/>

            <Button Content="Экпорт..."
            Style="{StaticResource GrayButton}"
            Command="{Binding ExportExcelCommand}"
            CommandParameter="{Binding ElementName=PivotGrid}"
            Margin="10,0,0,0"
            MinWidth="70"/>
        </StackPanel>

        <!-- PIVOT TABLE -->
        <DataGrid x:Name="PivotGrid"
                  Style="{StaticResource SummaryGrid}"
                  Grid.Row="1"
                  ItemsSource="{Binding PivotTable}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  RowHeaderWidth="0"
                  AlternationCount="2"
                  HorizontalScrollBarVisibility="Auto"/>
    </Grid>

</UserControl>
