<UserControl x:Class="PresentationWpf.Views.SaleTotalByGroupReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PresentationWpf.Views"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================== -->
        <!-- TOP FILTER PANEL -->
        <!-- ===================== -->
        <StackPanel Orientation="Horizontal"
            Margin="0,0,0,10"
            VerticalAlignment="Center">

            <!-- FROM DATE -->
            <TextBlock Text="С:"
               VerticalAlignment="Center"
               Margin="0,0,5,0"
               Height="30"/>

            <DatePicker SelectedDate="{Binding FromDate}"
                Width="140"
                FontSize="13"
                Margin="0,0,15,0" Height="30"/>

            <!-- TO DATE -->
            <TextBlock Text="По:"
               VerticalAlignment="Center"
               Margin="0,0,5,0" Height="30"/>

            <DatePicker SelectedDate="{Binding ToDate}"
                Width="140"
                FontSize="13"
                Margin="0,0,20,0" Height="30"/>

            <!-- REGION COMBO -->
            <TextBlock Text="Область:"
               VerticalAlignment="Center"
               Margin="0,0,5,0" Height="30"/>

            <ComboBox Width="160"
              IsEditable="True"
              IsTextSearchEnabled="True"
              ItemsSource="{Binding Regions}"
              SelectedItem="{Binding SelectedRegion, Mode=TwoWay}"
              FontSize="14"
              Margin="0,0,15,0"
             Height="30"/>

            <!-- BRAND COMBO -->
            <TextBlock Text="Бренд:"
               VerticalAlignment="Center"
               Margin="0,0,5,0" Height="30"/>

            <ComboBox Width="160"
              IsEditable="True"
              IsTextSearchEnabled="True"
              ItemsSource="{Binding Brands}"
              SelectedItem="{Binding SelectedBrand, Mode=TwoWay}"
              Height="30" FontSize="14"/>

            <Button Content="Экпорт..."
               Style="{StaticResource GrayButton}"
               Command="{Binding ExportExcelCommand}"
               CommandParameter="{Binding ElementName=PivotGrid}"
               Margin="10,0,0,0"
               MinWidth="70"/>

        </StackPanel>

        <!-- ===================== -->
        <!-- MAIN CONTENT -->
        <!-- ===================== -->
        <Grid Grid.Row="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <!-- LEFT SIDE : TABLE -->
            <DataGrid x:Name="PivotGrid"
               Grid.Row="0"
              ItemsSource="{Binding PivotTable}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              RowHeaderWidth="0"
              AlternationCount="2"
              Style="{StaticResource SummaryGrid}"
              Margin="0,0,10,0"/>

            <lvc:CartesianChart Grid.Row="1"
                    Series="{Binding SeriesCollection}"
                    LegendLocation="Right"
                    ClipToBounds="False" >

                <lvc:CartesianChart.AxisX>
                    <lvc:Axis Labels="{Binding Labels}"
                  LabelsRotation="35"
                  Foreground="#333">
                        <lvc:Axis.Separator>
                            <lvc:Separator Step="1"/>
                        </lvc:Axis.Separator>
                    </lvc:Axis>
                </lvc:CartesianChart.AxisX>

                <lvc:CartesianChart.AxisY>
                    <lvc:Axis Title="Всего продажа"
              LabelFormatter="{Binding Formatter}"
              FontSize="13"
              Foreground="#2C3E50"
              Margin="10,0,0,0">

                        <lvc:Axis.Separator>
                            <lvc:Separator Stroke="#E0E0E0"
                           StrokeThickness="1"/>
                        </lvc:Axis.Separator>

                    </lvc:Axis>
                </lvc:CartesianChart.AxisY>

            </lvc:CartesianChart>

        </Grid>

    </Grid>

</UserControl>
