<UserControl x:Class="PresentationWpf.Views.InactiveWarehouseProductsReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PresentationWpf.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FILTER PANEL -->
        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,10"
                    VerticalAlignment="Center">

            <TextBlock Text="С:"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>

            <DatePicker SelectedDate="{Binding FromDate}"
                        Width="130"
                        Height="30"
                        FontSize="14"
                        Margin="0,0,15,0"/>

            <TextBlock Text="По:"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>

            <DatePicker SelectedDate="{Binding ToDate}"
                        Width="130"
                        Height="30"
                        FontSize="14"
                        Margin="0,0,20,0"/>

            <TextBlock Text="Кол.меньше"
                       VerticalAlignment="Center"
                      
                       Margin="0,0,5,0"/>

            <TextBox Width="80"
                     Height="30"
                     FontSize="14"
                     VerticalAlignment="Center"
                     Text="{Binding QuantityLessThan, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,20,0"/>

            <Button Content="Печать"
                    Style="{StaticResource GrayButton}"
                    Width="100"
                    Height="30"
                    Command="{Binding PrintCommand}"
                    CommandParameter="{Binding ElementName=Root}"
                    Margin="0,0,10,0"/>

            <Button Content="Экспорт Excel"
                    Style="{StaticResource GrayButton}"
                    Width="130"
                    Height="30"
                    Command="{Binding ExportExcelCommand}"
                    CommandParameter="{Binding ElementName=ReportGrid}"/>

        </StackPanel>


        <!-- REPORT TABLE -->

        <DataGrid x:Name="ReportGrid"
                  Grid.Row="1"
                  Style="{StaticResource SummaryGrid}"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  RowHeaderWidth="0"
                  AlternationCount="2"
                  HorizontalScrollBarVisibility="Auto">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Артикул"
                                    Binding="{Binding ArticleNumber}"
                                    Width="120"/>

                <DataGridTextColumn Header="Наименование"
                                    Binding="{Binding ProductName}"
                                    Width="220"/>
                
               
                
                <DataGridTextColumn Header="Бренд"
                                    Binding="{Binding BrandName}"
                                    Width="110"/>
                <DataGridTextColumn Header="Марка"
                                     Binding="{Binding Marka}"
                                     Width="90"/>
                
                <DataGridTextColumn Header="Модель"
                                    Binding="{Binding Model}"
                                    Width="220"/>

                <DataGridTextColumn Header="Кол"
                                    Binding="{Binding Quentity}"
                                    Width="60"/>
                

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</UserControl>
