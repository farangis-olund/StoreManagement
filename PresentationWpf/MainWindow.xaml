    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

       
        <!-- Иконки/тексты -->
        <Style x:Key="CustomTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#babcbb"/>
        </Style>
      

        <Style x:Key="SidebarButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="Wheat"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <!-- Левая полоса -->
                            <Border x:Name="ActiveIndicator"
                            Width="4"
                            Background="Transparent"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"/>

                            <!-- Основной фон -->
                            <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                                <ContentPresenter VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Margin="10,0,0,0"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3E3B4E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>

                            <!-- Selected -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#403D56"/>
                                <Setter TargetName="ActiveIndicator" Property="Background" Value="#FFB347"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogoButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ArrowToggleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="Gold"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#FFC107"/>
                                <!-- lighter gold -->
                            </Trigger>
                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Foreground" Value="#FFA000"/>
                                <!-- darker gold -->
                            </Trigger>
                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="Gray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogoutButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Wheat"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0,0,0"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                        Background="{TemplateBinding Background}">

                            <ContentPresenter 
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3D3A4A"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#514C63"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.4"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarSeparatorStyle" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="14,10,14,10"/>
            <Setter Property="Background" Value="#4A465C"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="200"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
      

        <DockPanel Grid.Column="0" Margin="0,0,0,0" Background="#302D3E">

            <Button DockPanel.Dock="Top" Command="{Binding GoHomeCommand}"
               Style="{StaticResource LogoButtonStyle}">
                <StackPanel Background="#302D3E" Margin="0,0,0,0">
                    <Grid Background="#302D3E" Margin="0,20,0,0" Width="40">
                        <Image Source="Images/icons/wheel.png"/>
                    </Grid>
                    <TextBlock Text="AutoSpaire Store"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   FontSize="12"
                   Foreground="Wheat"
                   VerticalAlignment="Top"
                   Margin="0,0,0,20"/>
                </StackPanel>
            </Button>

            <StackPanel DockPanel.Dock="Top"
                Grid.Column="0" 
                Margin="0,0,0,0" 
                Background="#302D3E" 
                Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}">
                <!-- Group 1 -->
                <!-- Заказы-->
                <RadioButton 
                    GroupName="Sidebar" 
                    Height="50" 
                   Visibility="{Binding CanViewOrders, Converter={StaticResource BoolToVisibilityConverter}}"
   
                    Style="{StaticResource SidebarButtonStyle}" 
                    HorizontalContentAlignment="Left" 
                    Width="180" Background="Transparent" 
                    Command="{Binding NavigateToSaleListCommand}" 
                    Margin="0,0,0,0">
                    
                    <StackPanel Orientation="Horizontal">
                        <fa:FontAwesome Icon="ShoppingBasket"  Style="{StaticResource CustomTextBlockStyle}" FontSize="18" Margin="10,0,0,0"/>
                        <TextBlock Text="Заказы" FontSize="16"  Style="{StaticResource CustomTextBlockStyle}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </RadioButton>
                <!-- Возвраты-->
                <RadioButton GroupName="Sidebar" 
                      Visibility="{Binding CanViewReturns, Converter={StaticResource BoolToVisibilityConverter}}" 
                      Height="50" Style="{StaticResource SidebarButtonStyle}" HorizontalContentAlignment="Left" Width="180" Background="Transparent" Command="{Binding NavigateToReturnCommand}" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:FontAwesome Icon="Exchange"  Style="{StaticResource CustomTextBlockStyle}" FontSize="20" Margin="10,0,0,0"/>
                        <TextBlock Text="Возвраты" FontSize="16"  Style="{StaticResource CustomTextBlockStyle}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </RadioButton>
                <!-- Клиенты-->
                <RadioButton GroupName="Sidebar"
                     Visibility="{Binding CanViewCustomers, Converter={StaticResource BoolToVisibilityConverter}}"
                    Height="50" Style="{StaticResource SidebarButtonStyle}" HorizontalContentAlignment="Left"  Width="180" Background="Transparent" Command="{Binding NavigateCustomersListCommand}" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:FontAwesome Icon="User"  Style="{StaticResource CustomTextBlockStyle}" FontSize="18" Margin="10,0,0,0"/>
                        <TextBlock Text="Клиенты"  Style="{StaticResource CustomTextBlockStyle}" FontSize="16" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </RadioButton>
                
                <!-- Separator  -->
                <Border Style="{StaticResource SidebarSeparatorStyle}"/>
                
                <RadioButton GroupName="Sidebar" 
                              Visibility="{Binding CanViewInventory, Converter={StaticResource BoolToVisibilityConverter}}"
                             Height="50" Style="{StaticResource SidebarButtonStyle}" HorizontalContentAlignment="Left" Width="180" Background="Transparent" Command="{Binding NavigateToStockCommand}" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:FontAwesome Icon="Truck"  Style="{StaticResource CustomTextBlockStyle}" FontSize="18" Margin="10,0,0,0"/>
                        <TextBlock Text="Инвентарь" FontSize="16"  Style="{StaticResource CustomTextBlockStyle}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton GroupName="Sidebar" 
                 Visibility="{Binding CanViewExpenses, Converter={StaticResource BoolToVisibilityConverter}}"
                Height="50" Style="{StaticResource SidebarButtonStyle}" HorizontalContentAlignment="Left" Width="180" Background="Transparent" Command="{Binding NavigateToExpensesCommand}" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:FontAwesome Icon="Money"  Style="{StaticResource CustomTextBlockStyle}" FontSize="18" Margin="10,0,0,0"/>
                        <TextBlock Text="Расходы" FontSize="16"  Style="{StaticResource CustomTextBlockStyle}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </RadioButton>

                <!-- Separator  -->
                <Border Style="{StaticResource SidebarSeparatorStyle}"/>
                
                <RadioButton GroupName="Sidebar"
                              Visibility="{Binding CanViewReports, Converter={StaticResource BoolToVisibilityConverter}}" Height="50" Style="{StaticResource SidebarButtonStyle}" HorizontalContentAlignment="Left"  Width="180" Background="Transparent" Command="{Binding NavigateToReportsCommand}"  Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:FontAwesome Icon="Folder"  Style="{StaticResource CustomTextBlockStyle}" FontSize="18" Margin="10,0,0,0"/>
                        <TextBlock Text="Отчёты" FontSize="16"  Style="{StaticResource CustomTextBlockStyle}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton GroupName="Sidebar"
                              Visibility="{Binding CanViewStatistics, Converter={StaticResource BoolToVisibilityConverter}}" Height="50" Style="{StaticResource SidebarButtonStyle}" HorizontalContentAlignment="Left"  Width="180" Background="Transparent" Command="{Binding NavigateToStatisticsCommand}"  Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:FontAwesome Icon="BarChart"  Style="{StaticResource CustomTextBlockStyle}" FontSize="18" Margin="10,0,0,0"/>
                        <TextBlock Text="Статистика" FontSize="16" Style="{StaticResource CustomTextBlockStyle}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton GroupName="Sidebar"
                              Visibility="{Binding CanViewAdmin, Converter={StaticResource BoolToVisibilityConverter}}" Height="50" Style="{StaticResource SidebarButtonStyle}" HorizontalContentAlignment="Left"  Width="180" Background="Transparent" Command="{Binding NavigateToAdminCommand}"  Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:FontAwesome Icon="Lock"  Style="{StaticResource CustomTextBlockStyle}" FontSize="18" Margin="10,0,0,0"/>
                        <TextBlock Text="Администрация" FontSize="16" Style="{StaticResource CustomTextBlockStyle}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </RadioButton>

                <!-- Separator  -->
                <Border Style="{StaticResource SidebarSeparatorStyle}"/>
                
                <RadioButton GroupName="Sidebar"
                              Visibility="{Binding CanViewSettings, Converter={StaticResource BoolToVisibilityConverter}}" Height="50" Style="{StaticResource SidebarButtonStyle}" HorizontalContentAlignment="Left"  Width="180" Background="Transparent" Command="{Binding NavigateToProductsListCommand}"  Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <fa:FontAwesome Icon="Gear"  Style="{StaticResource CustomTextBlockStyle}" FontSize="18" Margin="10,0,0,0"/>
                        <TextBlock Text="Настройки" FontSize="16" Style="{StaticResource CustomTextBlockStyle}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </RadioButton>

                

            </StackPanel>

            <Button DockPanel.Dock="Bottom"
                Command="{Binding LogoutCommand}"
                Height="50"
                Background="Transparent"
                 Style="{StaticResource LogoutButtonStyle}"
                HorizontalContentAlignment="Center"
                Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}"
                Width="180"
                Margin="0,0,0,10">

                <StackPanel Orientation="Horizontal"    
                  >
                    <fa:FontAwesome Icon="SignOut" FontSize="18" Margin="10,2,0,0"/>
                    <TextBlock Text="Выход" FontSize="16" Margin="10,0,0,0"/>
                </StackPanel>
            </Button>

            <!-- Add a spacer to fill remaining space -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
            </Grid>
        </DockPanel>

        <Grid Grid.Column="1" Width="14" Background="#302D3E">
            <Button Content="⮜"
            Width="14" Height="50" FontSize="14"
            Click="ToggleSidebar_Click"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Style="{StaticResource ArrowToggleButtonStyle}"/>
        </Grid>




        <!-- Main Content Area -->
        <ContentControl Grid.Column="2" Content="{Binding CurrentViewModel}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type viewmodels:RetailViewModel}">
                    <views:RetailView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:ProductViewModel}">
                    <views:ProductView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:CustomerViewModel}">
                    <views:CustomerView/>
                </DataTemplate>
             

                <DataTemplate DataType="{x:Type viewmodels:WelcomeViewModel}">
                    <views:Welcome/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:LoginViewModel}">
                    <views:LoginView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:OrderInvoiceViewModel}">
                    <views:OrderInvoiceView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:SummaryViewModel}">
                    <views:SummaryWindow/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:PaymentReceiptViewModel}">
                    <views:PaymentReceiptView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:ReturnViewModel}">
                    <views:ReturnView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:CoefficientViewModel}">
                    <views:CoefficientView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:AdminViewModel}">
                    <views:AdminView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:ReturnInvoiceViewModel}">
                    <views:ReturnInvoiceView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:ReferenceViewModel}">
                    <views:ReferenceView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:StockViewModel}">
                    <views:StockView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:TransferViewModel}">
                    <views:TransferView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:MovementViewModel}">
                    <views:MovementView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:ImportViewModel}">
                    <views:ImportView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:ReportViewModel}">
                    <views:ReportView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type viewmodels:StockLocationViewModel}">
                    <views:StockLocationView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:PendingOrdersViewModel}">
                    <views:PendingOrdersView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:DeliveryOrdersViewModel}">
                    <views:DeliveryOrdersView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:AssignPickersViewModel}">
                    <views:AssignPickersView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:TransferReceiveViewModel}">
                    <views:TransferReceiveView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:ReturnDebtRepaymentViewModel}">
                    <views:ReturnDebtRepaymentView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:UserViewModel}">
                    <views:UserView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:ManagerViewModel}">
                    <views:ManagerView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:BrandViewModel}">
                    <views:BrandView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:BonusesViewModel}">
                    <views:BonusesView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:ManagerInfoViewModel}">
                    <views:ManagerInfoView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:CourierInfoViewModel}">
                    <views:CourierInfoView/>
                </DataTemplate>
                
                <DataTemplate DataType="{x:Type viewmodels:AssignPickerInfoViewModel}">
                    <views:AssignPickerInfoView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type viewmodels:CreateAdminViewModel}">
                    <views:CreateAdminView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:DataBaseViewModel}">
                    <views:DataBaseView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:RoleManagementViewModel}">
                    <views:RoleManagementView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:PermissionsViewModel}">
                    <views:PermissionsView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:PriceLevelViewModel}">
                    <views:PriceLevelView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:ReportsViewModel}">
                    <views:ReportsView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:SalesSummaryViewModel}">
                    <views:SalesSummaryView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:SaleTotalByGroupReportViewModel}">
                    <views:SaleTotalByGroupReportView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:SalesByGroupCustomerReportViewModel}">
                    <views:SalesByGroupCustomerReportView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:SalesManagerReportViewModel}">
                    <views:SalesManagerReportView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:StatisticsViewModel}">
                    <views:StatisticsView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:SalesDynamicsStatisticsViewModel}">
                    <views:SalesDynamicsStatisticsView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:InactiveWarehouseProductsReportViewModel}">
                    <views:InactiveWarehouseProductsReportView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:CourierStorekeeperReportViewModel}">
                    <views:CourierStorekeeperReportView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:WarehousePlaceReportViewModel}">
                    <views:WarehousePlaceReportView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:CustomerSalesPaymentsReportViewModel}">
                    <views:CustomerSalesPaymentsReportView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:TotalSalesReportViewModel}">
                    <views:TotalSalesReportView/>
                </DataTemplate>

                <DataTemplate DataType="{x:Type viewmodels:ExpenseCrudViewModel}">
                    <views:ExpenseCrudView/>
                </DataTemplate>

            </ContentControl.Resources>
        </ContentControl>

    </Grid>

</Window>
